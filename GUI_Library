        end

        function TabObj:CreateButton(text, callback)
            local btn = Instance.new("TextButton", scroll)
            btn.Size = UDim2.new(1,0,0,34); btn.BackgroundColor3 = T.Element
            btn.Text = text; btn.TextColor3 = T.Text
            btn.Font = Enum.Font.GothamSemibold; btn.TextSize = 12
            btn.AutoButtonColor = false
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,4)
            btn.MouseButton1Click:Connect(function()
                local t1 = TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3=T.Accent})
                local t2 = TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3=T.Element})
                t1:Play(); t1.Completed:Connect(function() t2:Play() end)
                callback(btn)
            end)
            local BtnObj = {}
            function BtnObj:Set(newText) btn.Text = newText end
            return BtnObj
        end

        return TabObj
    end

    if WindowConfig.AutoMinimize then ToggleMinimize(true) end
    return WindowObj
end

return BottleLib
