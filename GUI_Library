        tabBtn.MouseLeave:Connect(function() if currentTab.Btn ~= tabBtn then TweenService:Create(tabBtn, TweenInfo.new(0.18), {BackgroundColor3 = T.Sidebar}):Play() end end)

        local scroll = Instance.new("ScrollingFrame", ContentContainer)
        scroll.Size = UDim2.new(1, -10, 1, -10); scroll.Position = UDim2.new(0, 5, 0, 5); scroll.BackgroundTransparency = 1; scroll.ScrollBarThickness = 2; scroll.ScrollBarImageColor3 = T.Accent; scroll.BorderSizePixel = 0; scroll.Visible = false
        local layout = Instance.new("UIListLayout", scroll); layout.SortOrder = Enum.SortOrder.LayoutOrder; layout.Padding = UDim.new(0, 7)
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 18) end)

        tabBtn.MouseButton1Click:Connect(function()
            CloseAllDropdowns() -- 🛠️ ปิด Dropdown เมื่อเปลี่ยน Tab
            if currentTab then TweenService:Create(currentTab.Btn, TweenInfo.new(0.18), {BackgroundColor3 = T.Sidebar, TextColor3 = T.SubText}):Play(); TweenService:Create(currentTab.Line, TweenInfo.new(0.18), {BackgroundTransparency = 1}):Play(); currentTab.Frame.Visible = false end
            currentTab = {Btn = tabBtn, Frame = scroll, Line = line}
            TweenService:Create(tabBtn, TweenInfo.new(0.18), {BackgroundColor3 = Color3.fromRGB(26,26,26), TextColor3 = T.Text}):Play(); TweenService:Create(line, TweenInfo.new(0.18), {BackgroundTransparency = 0}):Play(); scroll.Visible = true
        end)
        
        table.insert(tabList, {Btn = tabBtn, Frame = scroll, Line = line})
        if #tabList == 1 then tabBtn.BackgroundColor3 = Color3.fromRGB(26,26,26); tabBtn.TextColor3 = T.Text; line.BackgroundTransparency = 0; scroll.Visible = true; currentTab = {Btn = tabBtn, Frame = scroll, Line = line} end

        local TabObj = {}
        
        -- 🛠️ สร้าง Label ที่แก้ไขอัปเดตแบบ Dynamic ได้
        function TabObj:CreateLabel(text)
            local l = Instance.new("TextLabel", scroll)
            l.Size = UDim2.new(1, 0, 0, 20); l.BackgroundTransparency = 1; l.Text = "  "..text; l.TextColor3 = T.SubText; l.Font = Enum.Font.GothamMedium; l.TextSize = 11; l.TextXAlignment = Enum.TextXAlignment.Left
            return { SetText = function(self, newText) l.Text = "  "..newText end }
        end

        function TabObj:CreateSection(text)
            local l = Instance.new("TextLabel", scroll)
            l.Size = UDim2.new(1, 0, 0, 22); l.BackgroundTransparency = 1; l.Text = "  "..text; l.TextColor3 = T.Accent; l.Font = Enum.Font.GothamBlack; l.TextSize = 11; l.TextXAlignment = Enum.TextXAlignment.Left
        end

        -- 🛠️ สร้างเส้นคั่น UI
        function TabObj:CreateSeparator()
            local sep = Instance.new("Frame", scroll)
            sep.Size = UDim2.new(1, 0, 0, 1); sep.BackgroundColor3 = T.ElemDark; sep.BorderSizePixel = 0
        end

        function TabObj:CreateToggle(label, init, callback)
            local btn = Instance.new("TextButton", scroll)
            btn.Size = UDim2.new(1, 0, 0, 34); btn.BackgroundColor3 = T.Element; btn.Text = "    "..label; btn.TextColor3 = T.Text; btn.Font = Enum.Font.GothamSemibold; btn.TextSize = 12; btn.TextXAlignment = Enum.TextXAlignment.Left; btn.AutoButtonColor = false
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
            local dot = Instance.new("Frame", btn); dot.Size = UDim2.new(0, 10, 0, 10); dot.Position = UDim2.new(1, -22, 0.5, -5); dot.BackgroundColor3 = init and T.Accent or Color3.fromRGB(60,60,60)
            Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
            local state = init
            btn.MouseButton1Click:Connect(function() state = not state; TweenService:Create(dot, TweenInfo.new(0.18), {BackgroundColor3 = state and T.Accent or Color3.fromRGB(60,60,60)}):Play(); callback(state) end)
            
            -- 🛠️ คืนค่า Set Function
            return { Set = function(self, newState) state = newState; TweenService:Create(dot, TweenInfo.new(0.18), {BackgroundColor3 = state and T.Accent or Color3.fromRGB(60,60,60)}):Play(); callback(state) end }
        end

        function TabObj:CreateSlider(label, min, max, default, callback)
            local frame = Instance.new("Frame", scroll); frame.Size = UDim2.new(1, 0, 0, 48); frame.BackgroundColor3 = T.Element; Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 4)
            local lbl = Instance.new("TextLabel", frame); lbl.Size = UDim2.new(1, -10, 0, 18); lbl.Position = UDim2.new(0, 8, 0, 4); lbl.BackgroundTransparency = 1; lbl.TextColor3 = T.Text; lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 11; lbl.TextXAlignment = Enum.TextXAlignment.Left
            local track = Instance.new("TextButton", frame); track.Size = UDim2.new(0.93, 0, 0, 6); track.Position = UDim2.new(0.035, 0, 0, 34); track.BackgroundColor3 = Color3.fromRGB(50,50,50); track.Text = ""; track.AutoButtonColor = false; Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
            local fill = Instance.new("Frame", track); fill.Size = UDim2.new(math.clamp((default-min)/(max-min), 0, 1), 0, 1, 0); fill.BackgroundColor3 = T.Accent; Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
            local function update(v) local res = callback(v); lbl.Text = label..": "..(res or v) end
            update(default)
            
            -- 🛠️ Slider Connection Fix (ไม่ให้ค้าง Memory)
            local dragConn, relConn
            track.MouseButton1Down:Connect(function()
                dragConn = UserInputService.InputChanged:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseMovement then 
                        local p = math.clamp((UserInputService:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1); fill.Size = UDim2.new(p, 0, 1, 0); update(math.floor(min + (max-min)*p)) 
                    end
                end)
                relConn = UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then 
                        if dragConn then dragConn:Disconnect() end; if relConn then relConn:Disconnect() end 
                    end
                end)
            end)
        end

        function TabObj:CreateDropdown(placeholder, optionsList, callback)
            local frame = Instance.new("Frame", scroll); frame.Size = UDim2.new(1, 0, 0, 34); frame.BackgroundColor3 = T.Element; Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 4)
            local Input = Instance.new("TextBox", frame); Input.Size = UDim2.new(1, -10, 1, 0); Input.Position = UDim2.new(0, 10, 0, 0); Input.BackgroundTransparency = 1; Input.Text = ""; Input.PlaceholderText = "🔍 " .. placeholder; Input.TextColor3 = T.Text; Input.PlaceholderColor3 = T.SubText; Input.Font = Enum.Font.GothamSemibold; Input.TextSize = 11; Input.TextXAlignment = Enum.TextXAlignment.Left
            local DropOverlay = Instance.new("Frame", ScreenGui); DropOverlay.Size = UDim2.new(0, 220, 0, 160); DropOverlay.BackgroundColor3 = Color3.fromRGB(14,14,14); DropOverlay.Visible = false; DropOverlay.ZIndex = 80; Instance.new("UICorner", DropOverlay).CornerRadius = UDim.new(0, 6); Instance.new("UIStroke", DropOverlay).Color = T.Accent
            local DScroll = Instance.new("ScrollingFrame", DropOverlay); DScroll.Size = UDim2.new(1,-4,1,-4); DScroll.Position = UDim2.new(0,2,0,2); DScroll.BackgroundTransparency = 1; DScroll.ScrollBarThickness = 3; DScroll.ScrollBarImageColor3 = T.Accent; DScroll.BorderSizePixel = 0; DScroll.ZIndex = 81; Instance.new("UIListLayout", DScroll).SortOrder = Enum.SortOrder.LayoutOrder

            local function RefreshList(filter)
                for _, c in ipairs(DScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                local count = 0
                for _, item in ipairs(optionsList) do
                    if not filter or filter == "" or string.find(string.lower(item), string.lower(filter)) then
                        count = count + 1
                        local b = Instance.new("TextButton", DScroll); b.Size = UDim2.new(1,0,0,30); b.BackgroundColor3 = Color3.fromRGB(22,22,22); b.Text = "  "..item; b.TextColor3 = T.Text; b.Font = Enum.Font.GothamMedium; b.TextSize = 11; b.TextXAlignment = Enum.TextXAlignment.Left; b.ZIndex = 82
                        b.MouseButton1Click:Connect(function() Input.Text = item; callback(item); CloseAllDropdowns() end)
                    end
                end
                DScroll.CanvasSize = UDim2.new(0,0,0, count * 30 + 4)
            end

            Input.Focused:Connect(function()
                CloseAllDropdowns() -- 🛠️ ป้องกันการเปิดซ้อนทับกัน
                local pos = frame.AbsolutePosition; local sz = frame.AbsoluteSize
                local yPos = pos.Y + sz.Y + 4; if yPos + 160 > ScreenGui.AbsoluteSize.Y then yPos = pos.Y - 160 - 4 end
                DropOverlay.Position = UDim2.new(0, pos.X, 0, yPos); DropOverlay.Size = UDim2.new(0, math.max(sz.X, 220), 0, 160)
                RefreshList(Input.Text); DropOverlay.Visible = true; GlobalOverlayClose.Visible = true
                ActiveDropdownFrame = DropOverlay
            end)
            Input:GetPropertyChangedSignal("Text"):Connect(function() if DropOverlay.Visible then RefreshList(Input.Text) end end)
            Input.FocusLost:Connect(function() if Input.Text ~= "" then callback(Input.Text) end end)
            
            return { Set = function(self, newText) Input.Text = newText; callback(newText) end }
        end

        function TabObj:CreateDualKeyRow(l1, l2, callback1, callback2)
            local frame = Instance.new("Frame", scroll); frame.Size = UDim2.new(1, 0, 0, 36); frame.BackgroundColor3 = T.Element; Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 4)
            local function Pair(labelStr, ox, cb)
                local l = Instance.new("TextLabel", frame); l.Size = UDim2.new(0.22, 0, 1, 0); l.Position = UDim2.new(ox, 4, 0, 0); l.BackgroundTransparency = 1; l.Text = labelStr; l.TextColor3 = T.SubText; l.Font = Enum.Font.GothamMedium; l.TextSize = 10
                local b = Instance.new("TextBox", frame); b.Size = UDim2.new(0.18, 0, 0.65, 0); b.Position = UDim2.new(ox+0.22, 0, 0.175, 0); b.BackgroundColor3 = T.ElemDark; b.TextColor3 = T.Accent; b.Font = Enum.Font.GothamBold; b.Text = ""; b.ClearTextOnFocus = false; Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
                b.FocusLost:Connect(function() local t = b.Text; if t == "" or t == " " then cb(""); return end; local ok = pcall(function() return Enum.KeyCode[t:upper()] end); if ok then cb(t:upper()); b.Text = t:upper() else b.Text = "" end end)
            end
            Pair(l1, 0.02, callback1); Pair(l2, 0.52, callback2)
        end

        function TabObj:CreateDualNumRow(l1, l2, callback1, callback2)
            local frame = Instance.new("Frame", scroll); frame.Size = UDim2.new(1, 0, 0, 36); frame.BackgroundColor3 = T.Element; Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 4)
            local function Pair(labelStr, ox, cb)
                local l = Instance.new("TextLabel", frame); l.Size = UDim2.new(0.28, 0, 1, 0); l.Position = UDim2.new(ox, 4, 0, 0); l.BackgroundTransparency = 1; l.Text = labelStr; l.TextColor3 = T.SubText; l.Font = Enum.Font.GothamMedium; l.TextSize = 10
                local b = Instance.new("TextBox", frame); b.Size = UDim2.new(0.18, 0, 0.65, 0); b.Position = UDim2.new(ox+0.28, 0, 0.175, 0); b.BackgroundColor3 = T.ElemDark; b.TextColor3 = T.Accent; b.Font = Enum.Font.GothamBold; b.Text = "0"; b.ClearTextOnFocus = false; Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
                b.FocusLost:Connect(function() local v = tonumber(b.Text); if v then cb(v) else b.Text = "0" end end)
            end
            Pair(l1, 0.02, callback1); Pair(l2, 0.52, callback2)
        end

        -- 🛠️ Button Flash Animation Fix
        function TabObj:CreateButton(text, callback)
            local btn = Instance.new("TextButton", scroll); btn.Size = UDim2.new(1, 0, 0, 34); btn.BackgroundColor3 = T.Element; btn.Text = text; btn.TextColor3 = T.Text; btn.Font = Enum.Font.GothamSemibold; btn.TextSize = 12; btn.AutoButtonColor = false; Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
            btn.MouseButton1Click:Connect(function() 
                local twIn = TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = T.Accent})
                twIn:Play(); twIn.Completed:Wait()
                TweenService:Create(btn, TweenInfo.new(0.18), {BackgroundColor3 = T.Element}):Play()
                callback(btn) 
            end)
        end
        return TabObj
    end

    if WindowConfig.AutoMinimize then ToggleMinimize(true) end
    return WindowObj
end

return BottleLib
