        -- ──────────────────────────────────────────────────────
        -- [PATCH 2] SLIDER — V10.4
        --
        -- ปัญหาใน V10.3:
        --   trackHit.MouseButton1Down(x,y) + track.AbsolutePosition
        --   AbsolutePosition ใน gethui() ≠ screen coords ที่ x,y จาก MouseButton1Down ใช้
        --   → ratio calculation ผิด → fill ไม่ขยับในทิศที่ถูก
        --
        -- การแก้ไข V10.4:
        --   trackHit.MouseEnter / MouseLeave เพื่อ track hover แทน bounds check
        --   UIS.InputBegan เมื่อ mouseOverTrack=true → dragStartPos = input.Position (UIS space)
        --   dx = input.Position.X - dragStartPos.X (UIS space ทั้งคู่ → ถูกต้อง)
        --   normalize ด้วย track.AbsoluteSize.X (SIZE ไม่ใช่ POSITION → ไม่มี space mismatch)
        -- ──────────────────────────────────────────────────────
        function TabObj:CreateSlider(label, min, max, default, callback)
            local frame = Instance.new("Frame", scroll)
            frame.Size = UDim2.new(1,0,0,48); frame.BackgroundColor3 = T.Element
            Instance.new("UICorner", frame).CornerRadius = UDim.new(0,4)

            local lbl = Instance.new("TextLabel", frame)
            lbl.Size = UDim2.new(1,-10,0,18); lbl.Position = UDim2.new(0,8,0,4)
            lbl.BackgroundTransparency = 1; lbl.TextColor3 = T.Text
            lbl.Font = Enum.Font.GothamBold; lbl.TextSize = 11
            lbl.TextXAlignment = Enum.TextXAlignment.Left

            -- visual track (Frame, ไม่รับ input โดยตรง)
            local track = Instance.new("Frame", frame)
            track.Size = UDim2.new(1,-20,0,6); track.Position = UDim2.new(0,10,0,34)
            track.BackgroundColor3 = Color3.fromRGB(50,50,50); track.BorderSizePixel = 0
            Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

            local fill = Instance.new("Frame", track)
            fill.Size = UDim2.new(math.clamp((default-min)/(max-min),0,1), 0, 1, 0)
            fill.BackgroundColor3 = T.Accent; fill.BorderSizePixel = 0
            Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)

            -- trackHit: transparent TextButton ขนาดใหญ่กว่า track, ZIndex=3
            local trackHit = Instance.new("TextButton", frame)
            trackHit.Size     = UDim2.new(1,-20,0,30)
            trackHit.Position = UDim2.new(0,10,0,24)
            trackHit.BackgroundTransparency = 1
            trackHit.Text = ""; trackHit.ZIndex = 3; trackHit.AutoButtonColor = false

            local function update(v)
                local res = callback(v)
                lbl.Text = label .. ": " .. (res or v)
            end
            update(default)

            local sliderDragging   = false
            local sliderStartPos   = nil
            local sliderStartRatio = math.clamp((default-min)/(max-min), 0, 1)
            local mouseOverTrack   = false

            -- [PATCH 2] MouseEnter/MouseLeave — ไม่มีการคำนวณตำแหน่งเลย
            trackHit.MouseEnter:Connect(function() mouseOverTrack = true  end)
            trackHit.MouseLeave:Connect(function() mouseOverTrack = false end)

            local sc0 = UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                if not mouseOverTrack then return end
                sliderDragging   = true
                sliderStartPos   = input.Position
                sliderStartRatio = fill.Size.X.Scale
            end)

            local c1 = UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliderDragging = false
                end
            end)

            local c2 = UserInputService.InputChanged:Connect(function(i)
                if not sliderDragging then return end
                if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                -- dx และ sliderStartPos ทั้งคู่มาจาก UIS → same coordinate space
                -- track.AbsoluteSize.X คือ SIZE ไม่ใช่ POSITION → ปลอดภัยจาก space mismatch
                local trackW   = math.max(track.AbsoluteSize.X, 1)
                local dx       = i.Position.X - sliderStartPos.X
                local newRatio = math.clamp(sliderStartRatio + dx / trackW, 0, 1)
                fill.Size      = UDim2.new(newRatio, 0, 1, 0)
                update(math.floor(min + (max-min)*newRatio))
                sliderStartPos   = i.Position
                sliderStartRatio = newRatio
            end)

            table.insert(BottleLib.Connections, sc0)
            table.insert(BottleLib.Connections, c1)
            table.insert(BottleLib.Connections, c2)
        end

