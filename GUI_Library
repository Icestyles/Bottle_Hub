local function ExecuteServerHop(targetCount)
    SafeSetStatus("Status: Searching for server...")
    targetCount = tonumber(targetCount) or 0
    local cursor, bestServer, lowestPlayers = "", nil, math.huge
    
    while cursor ~= nil and not bestServer and State.IsRunning do
        local url = ("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100"):format(game.PlaceId)
        if cursor ~= "" then url = url .. "&cursor=" .. cursor end
        local ok, raw = pcall(function() return game:HttpGet(url) end)
        
        if ok and raw then
            local data = HttpService:JSONDecode(raw)
            if data and data.data then
                for _, srv in ipairs(data.data) do
                    if srv.id ~= game.JobId and srv.playing < srv.maxPlayers and srv.playing > 0 then
                        if targetCount > 0 then 
                            if srv.playing == targetCount then bestServer = srv.id; break end
                        else
                            if srv.playing < lowestPlayers then lowestPlayers = srv.playing; bestServer = srv.id end
                            if srv.playing <= 2 then bestServer = srv.id; break end
                        end
                    end
                end
                if bestServer and (targetCount > 0 or lowestPlayers <= 2) then break end
                cursor = data.nextPageCursor
            else break end
        else break end
        task.wait(0.2)
    end
    
    if bestServer then 
        SafeSetStatus("Status: Teleporting...")
        TeleportService:TeleportToPlaceInstance(game.PlaceId, bestServer, player) 
    else
        SafeSetStatus("Status: Hop Failed (Cooldown)")
    end
end

