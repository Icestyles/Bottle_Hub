            local selectedFromList = false 
            local function RefreshList(filter)
                for _, c in ipairs(DScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                local count = 0
                for _, item in ipairs(optionsList) do
                    if not filter or filter == "" or string.find(string.lower(item), string.lower(filter)) then
                        count = count + 1
                        local b = Instance.new("TextButton", DScroll); b.Size = UDim2.new(1,0,0,30); b.BackgroundColor3 = Color3.fromRGB(22,22,22); b.Text = "  "..item; b.TextColor3 = T.Text; b.Font = Enum.Font.GothamMedium; b.TextSize = 11; b.TextXAlignment = Enum.TextXAlignment.Left; b.ZIndex = 82
                        b.MouseButton1Click:Connect(function() 
                            selectedFromList = true
                            Input.Text = item; callback(item)
                            DropOverlay.Visible = false; WindowObj.ActiveDropdown = nil; GlobalOverlayClose.Visible = false 
                        end)
                    end
                end
                DScroll.CanvasSize = UDim2.new(0,0,0, count * 30 + 4)
            end

            Input.Focused:Connect(function()
                if WindowObj.ActiveDropdown and WindowObj.ActiveDropdown ~= DropOverlay then WindowObj.ActiveDropdown.Visible = false end
                WindowObj.ActiveDropdown = DropOverlay
                local pos = frame.AbsolutePosition; local sz = frame.AbsoluteSize
                local yPos = pos.Y + sz.Y + 4; if yPos + 160 > ScreenGui.AbsoluteSize.Y then yPos = pos.Y - 160 - 4 end
                DropOverlay.Position = UDim2.new(0, pos.X, 0, yPos); DropOverlay.Size = UDim2.new(0, math.max(sz.X, 220), 0, 160)
                RefreshList(Input.Text); DropOverlay.Visible = true; GlobalOverlayClose.Visible = true
            end)
            Input:GetPropertyChangedSignal("Text"):Connect(function() if DropOverlay.Visible and not selectedFromList then RefreshList(Input.Text) end end)
            
            Input.FocusLost:Connect(function() 
                if selectedFromList then selectedFromList = false; return end
                if Input.Text ~= "" then callback(Input.Text) end 
            end)
        end

