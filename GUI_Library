-- ⚔️ Auto Slap
local SlapRequest = ReplicatedStorage:FindFirstChild("SlapRequest")
task.spawn(function()
    while State.IsRunning do
        if not State.AutoSlap then 
            SafeSetStatus("Status: Idle")
            task.wait(0.5); continue 
        end
        
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChild("Humanoid")
        
        if root and hum and hum.Health > 0 and not IsSafeZone(root.Position) then
            local closest, shortest = nil, State.AutoAimRange
            local targets = {}
            
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character then table.insert(targets, p.Character) end
            end
            for _, fn in ipairs({"SpawnedEntities","Mobs","Enemies","Live","NPCs"}) do
                local f = workspace:FindFirstChild(fn)
                if f then
                    for _, obj in ipairs(f:GetChildren()) do
                        if obj:IsA("Model") and obj ~= char and not Players:GetPlayerFromCharacter(obj) then table.insert(targets, obj) end
                    end
                end
            end
            
            for _, tChar in ipairs(targets) do
                local tRoot = tChar:FindFirstChild("HumanoidRootPart")
                local tHum  = tChar:FindFirstChild("Humanoid")
                if tRoot and tHum and tHum.Health > 0 then
                    local d = (root.Position - tRoot.Position).Magnitude
                    if d <= shortest then shortest = d; closest = tChar end
                end
            end
            
            if closest and closest:FindFirstChild("HumanoidRootPart") then
                SafeSetStatus("Status: Attacking " .. closest.Name)
                root.CFrame = CFrame.lookAt(root.Position, Vector3.new(closest.HumanoidRootPart.Position.X, root.Position.Y, closest.HumanoidRootPart.Position.Z))
                if shortest <= 8 then
                    pcall(function()
                        local wn = GetEquippedWeaponName()
                        if wn ~= "" and wn ~= "(No items found)" then
                            if SlapRequest then SlapRequest:FireServer(wn) end
                            local tool = char:FindFirstChild(wn)
                            if tool and tool:IsA("Tool") then tool:Activate() end
                        else
                            if SlapRequest then SlapRequest:FireServer("Combat") end
                        end
                    end)
                    task.wait(0.3)
                else task.wait(0.1) end
            else 
                SafeSetStatus("Status: Searching for target...")
                task.wait(0.1) 
            end
        else task.wait(0.2) end
    end
end)

-- ⌨️ Auto Skill
local function pressKey(keyStr)
    if keyStr and keyStr ~= "" and keyStr ~= " " then
        pcall(function()
            if VirtualInputManager then
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode[keyStr], false, game)
                task.wait(0.05)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode[keyStr], false, game)
            end
        end)
    end
end

task.spawn(function()
    while State.IsRunning do
        if State.AutoKey then
            local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            local myHum  = player.Character and player.Character:FindFirstChild("Humanoid")
            if myRoot and myHum and myHum.Health > 0 and not IsSafeZone(myRoot.Position) then
                if State.Key1 ~= "" then pressKey(State.Key1) end
                task.wait(State.KeyDelay)
                if not State.AutoKey or not State.IsRunning then continue end
                if State.Key2 ~= "" then pressKey(State.Key2) end
                task.wait(State.KeyDelay)
            else task.wait(0.5) end
        else task.wait(0.2) end
    end
end)

-- 🟡 [Fix 4: Refined Morph Logic]
task.spawn(function()
    local morphRemote = ReplicatedStorage:WaitForChild("MorphRequest", 5)
    while State.IsRunning do
        if State.AutoMorph and State.MorphName ~= "" and morphRemote then
            local pChar = player.Character
            local hum = pChar and pChar:FindFirstChild("Humanoid")
            
            if pChar and hum and hum.Health > 0 then
                local mp = pChar:FindFirstChild("MorphName")
                local currentVal = mp and mp.Value or ""
                
                if currentVal ~= State.MorphName then
                    pcall(function()
                        morphRemote:FireServer(State.MorphName)
                        local PM = ReplicatedStorage:FindFirstChild("PowerManager")
                        if PM then require(PM):SetActivePower(State.MorphName) end
                    end)
                    task.wait(2) 
                end
            end
        end
        task.wait(0.5)
    end
end)

-- 🔴 [Fix 5: Strict Tool Checking]
task.spawn(function()
    local equipRemote = ReplicatedStorage:WaitForChild("EquipItemEvent", 5)
    while State.IsRunning do
        if State.AutoEquip and State.EquipItemName ~= "" and State.EquipItemName ~= "(No items found)" then
            local pChar = player.Character
            local hum = pChar and pChar:FindFirstChild("Humanoid")
            if pChar and hum and hum.Health > 0 then
                -- หา Tool ที่ถืออยู่จริงๆ
                local isHolding = false
                local heldItem = pChar:FindFirstChild(State.EquipItemName)
                if heldItem and heldItem:IsA("Tool") then isHolding = true end
                
                if not isHolding then
                    local toolInBackpack = player.Backpack:FindFirstChild(State.EquipItemName)
                    if toolInBackpack and toolInBackpack:IsA("Tool") then 
                        pcall(function() hum:EquipTool(toolInBackpack) end)
                    else
                        if equipRemote then pcall(function() equipRemote:FireServer(State.EquipItemName) end); task.wait(0.5) end
                        local toolAfter = player.Backpack:FindFirstChild(State.EquipItemName)
                        if toolAfter and toolAfter:IsA("Tool") then pcall(function() hum:EquipTool(toolAfter) end) end
                    end
                end
            end
        end
        task.wait(0.5)
    end
end)

