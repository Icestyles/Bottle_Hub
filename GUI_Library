    InputBox.Focused:Connect(function() TweenService:Create(InputStr,TweenInfo.new(0.3),{Color=Color3.fromHex("#e60852")}):Play() end)
    InputBox.FocusLost:Connect(function() TweenService:Create(InputStr,TweenInfo.new(0.3),{Color=Color3.fromRGB(40,40,40)}):Play() end)

    local VerifyBtn = Instance.new("TextButton", MF)
    VerifyBtn.Size = UDim2.new(1,-50,0,40); VerifyBtn.Position = UDim2.new(0,25,0,125); VerifyBtn.BackgroundColor3 = Color3.fromHex("#e60852"); VerifyBtn.Text = "Verify"
    VerifyBtn.TextColor3 = Color3.fromRGB(255,255,255); VerifyBtn.Font = Enum.Font.GothamBold; VerifyBtn.TextSize = 14; Instance.new("UICorner", VerifyBtn).CornerRadius = UDim.new(0,8)

    local GetKeyBtn = Instance.new("TextButton", MF)
    GetKeyBtn.Text = "Get Key"; GetKeyBtn.Size = UDim2.new(1,0,0,20); GetKeyBtn.Position = UDim2.new(0,0,1,-25); GetKeyBtn.BackgroundTransparency = 1
    GetKeyBtn.TextColor3 = Color3.fromRGB(100,100,100); GetKeyBtn.Font = Enum.Font.Gotham; GetKeyBtn.TextSize = 12
    GetKeyBtn.MouseButton1Click:Connect(function() pcall(function() setclipboard(SECRETS.Discord) end); GetKeyBtn.Text = "Copied!"; task.wait(1.5); GetKeyBtn.Text = "Get Key" end)

    VerifyBtn.MouseButton1Click:Connect(function()
        local input = string.upper(InputBox.Text)
        if input == "" then return end
        VerifyBtn.Text = "Checking..."
        local isValid, isExpired, _, expTime, isGlobal = VerifyKeyWithServer(input)
        if isValid and not isExpired then
            if not isGlobal then SaveKey(input, expTime) end
            BottleLib.KeyStatus = { Valid = true, ExpiresAt = tonumber(expTime), IsGlobal = isGlobal }
            VerifyBtn.Text = "Success!"; VerifyBtn.BackgroundColor3 = Color3.fromRGB(46,204,113)
            task.wait(0.5); KeyScreen:Destroy(); KeyVerified = true; VerifyEvent:Fire()
        else
            if isExpired then RemoveStoredKey() end
            VerifyBtn.Text = isExpired and "Key Expired" or "Invalid Key"
            VerifyBtn.BackgroundColor3 = Color3.fromRGB(231,76,60); task.wait(1.5); VerifyBtn.Text = "Verify"; VerifyBtn.BackgroundColor3 = Color3.fromHex("#e60852")
        end
    end)
    VerifyEvent.Event:Wait()
    return true
end

