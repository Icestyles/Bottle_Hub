local function RefreshDataLists()
    pcall(function()
        local scrollFrame = player.PlayerGui:FindFirstChild("Tranformar") and player.PlayerGui.Tranformar:FindFirstChild("TrocarPersonagem") and player.PlayerGui.Tranformar.TrocarPersonagem:FindFirstChild("ScrollingFrame")
