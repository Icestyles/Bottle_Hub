function BottleLib:CreateWindow(WindowConfig, SubTitle)
    BottleLib.CleanUpEvent:Fire()

    if type(WindowConfig) == "string" then
        WindowConfig = { Name = WindowConfig, SubTitle = SubTitle }
    end

    local HubName    = WindowConfig.Name  or "BOTTLEHUB"
    local ThemeColor = WindowConfig.Color or Color3.fromHex("#e60852")

    local T = {
        Main     = Color3.fromRGB(10,10,10),   Sidebar  = Color3.fromRGB(15,15,15),
        Content  = Color3.fromRGB(6,6,6),      Accent   = ThemeColor,
        Text     = Color3.fromRGB(255,255,255), SubText  = Color3.fromRGB(180,180,180),
        Element  = Color3.fromRGB(28,28,28),   ElemDark = Color3.fromRGB(18,18,18),
        Green    = Color3.fromRGB(46,204,113), Red      = Color3.fromRGB(231,76,60),
        Yellow   = Color3.fromRGB(255,200,50)
    }

    if CoreGui:FindFirstChild("BOTTLEHUB_MAIN") then CoreGui.BOTTLEHUB_MAIN:Destroy() end
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "BOTTLEHUB_MAIN"
    ScreenGui.Parent = (gethui and gethui()) or CoreGui

    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Size = UDim2.new(0,600,0,480); MainFrame.Position = UDim2.new(0.5,-300,0.5,-240)
    MainFrame.BackgroundColor3 = T.Main; MainFrame.Active = true
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0,8)
    local MFStroke = Instance.new("UIStroke", MainFrame)
    MFStroke.Color = T.Accent; MFStroke.Thickness = 1.5

    TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.new(0,660,0,520), Position = UDim2.new(0.5,-330,0.5,-260)
    }):Play()

    local ContentContainer = Instance.new("Frame", MainFrame)
    ContentContainer.Size     = UDim2.new(0,441,1,-24)
    ContentContainer.Position = UDim2.new(0,207,0,12)
    ContentContainer.BackgroundColor3 = T.Content; ContentContainer.BorderSizePixel = 0
    Instance.new("UICorner", ContentContainer).CornerRadius = UDim.new(0,6)

    -- ──────────────────────────────────────────────────────────
    -- Drag variables (TopBar สร้างหลัง Sidebar — ดูด้านล่าง)
    -- ──────────────────────────────────────────────────────────
    local dragging    = false
    local dragStartPos             -- Vector3 จาก UIS.InputBegan
    local frameStartPos            -- UDim2 ณ ขณะเริ่ม drag
    local mouseOverTopBar = false  -- set โดย TopBar.MouseEnter / MouseLeave

    -- ──────────────────────────────────────────────────────────
    -- Minimize
    -- ──────────────────────────────────────────────────────────
    local MiniButton = Instance.new("ImageButton", ScreenGui)
    MiniButton.Size = UDim2.new(0,42,0,42); MiniButton.Position = UDim2.new(0,10,0,10)
    MiniButton.Image = "rbxassetid://78690743314126"
    MiniButton.BackgroundColor3 = T.Main; MiniButton.Visible = false
    Instance.new("UICorner", MiniButton).CornerRadius = UDim.new(0,8)
    Instance.new("UIStroke", MiniButton).Color = T.Accent

    local function ToggleMinimize(hide)
        MainFrame.Visible  = not hide
        MiniButton.Visible = hide
    end
    MiniButton.MouseButton1Click:Connect(function() ToggleMinimize(false) end)

    -- ──────────────────────────────────────────────────────────
    -- [PATCH 3] LEFT CTRL — V10.3
    --
    -- ปัญหาใน V10.2:
    --   UIS.InputBegan event สำหรับ keyboard ไม่ reliable ใน executor บางตัว
    --   GetFocusedTextBox() อาจคืน non-nil unexpectedly → early return ตลอด
    --
    -- การแก้ไข V10.3:
    --   ใช้ RunService.Heartbeat + IsKeyDown() polling แทน event callback
    --   IsKeyDown() คือ query function → reliable ทุก executor ไม่ขึ้นกับ event hook
    --   debounce ด้วย ctrlWasDown เพื่อ fire แค่ครั้งเดียวต่อการกด
    -- ──────────────────────────────────────────────────────────
    local ctrlWasDown = false
    local ctrlConn = RunService.Heartbeat:Connect(function()
        if not MainFrame or not MainFrame.Parent then return end
        local ok, isDown = pcall(function()
            return UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
        end)
        if not ok then return end
        -- rising edge: กดลงครั้งแรก (ไม่ค้างไว้)
        if isDown and not ctrlWasDown then
            local focused = false
            pcall(function() focused = UserInputService:GetFocusedTextBox() ~= nil end)
            if not focused then
                ToggleMinimize(MainFrame.Visible)
            end
        end
        ctrlWasDown = isDown
    end)
    table.insert(BottleLib.Connections, ctrlConn)

    -- ──────────────────────────────────────────────────────────
    -- Sidebar
    -- ──────────────────────────────────────────────────────────
    local Sidebar = Instance.new("Frame", MainFrame)
    Sidebar.Size = UDim2.new(0,195,1,0)
    Sidebar.BackgroundColor3 = T.Sidebar; Sidebar.BorderSizePixel = 0
    Instance.new("UICorner", Sidebar).CornerRadius = UDim.new(0,8)

    local SbCover = Instance.new("Frame", Sidebar)
    SbCover.Size = UDim2.new(0,10,1,0); SbCover.Position = UDim2.new(1,-10,0,0)
    SbCover.BackgroundColor3 = T.Sidebar; SbCover.BorderSizePixel = 0

    local function MakeDot(xOff, color, label)
        local b = Instance.new("TextButton", Sidebar)
        b.Size = UDim2.new(0,13,0,13); b.Position = UDim2.new(0,xOff,0,14)
        b.BackgroundColor3 = color; b.Text = ""; b.AutoButtonColor = false
        Instance.new("UICorner", b).CornerRadius = UDim.new(1,0)
        local l = Instance.new("TextLabel", b)
        l.Size = UDim2.new(1,0,1,0); l.BackgroundTransparency = 1
        l.Text = label; l.TextColor3 = Color3.new(1,1,1)
        l.Font = Enum.Font.GothamBold; l.TextSize = 9
        return b
    end
    local RedDot    = MakeDot(14, Color3.fromRGB(255,69,58),  "X")
    local YellowDot = MakeDot(33, Color3.fromRGB(255,159,10), "-")
    RedDot.MouseButton1Click:Connect(function()
        BottleLib.CleanUpEvent:Fire(); ScreenGui:Destroy()
    end)
    YellowDot.MouseButton1Click:Connect(function() ToggleMinimize(true) end)

    -- ──────────────────────────────────────────────────────────
    -- [PATCH 1] DRAG — V10.4  (สร้างหลัง Sidebar)
    --
    -- ปัญหาใน V10.3:
    --   DragHandle สร้าง "ก่อน" Sidebar → Sidebar (สร้างทีหลัง, ZIndex เดียวกัน=1)
    --   render ทับ DragHandle → DragHandle.MouseButton1Down ไม่มีทาง fire ได้
    --   TabScrollContainer (ScrollingFrame) ดักจับ input ก่อน → click ผ่านลงไม่ถึง
    --
    -- การแก้ไข V10.4:
    --   TopBar TextButton ZIndex=10 สร้าง "หลัง" Sidebar → อยู่เหนือทุก element ใน Sidebar
    --   ครอบ full-width 40px ที่ top → Tab buttons เริ่มที่ Y=40+ จึงไม่ถูกบัง
    --   RedDot/YellowDot ตั้ง ZIndex=15 → อยู่เหนือ TopBar → ยังคลิกได้ปกติ
    --
    --   ใช้ TopBar.MouseEnter/MouseLeave เพื่อ track hover
    --   → ไม่ต้อง GetMouseLocation() หรือ AbsolutePosition ในการ check เลย
    --   ใช้ UIS.InputBegan เมื่อ mouseOverTopBar=true → dragStart = input.Position
    --   ใช้ UIS.InputChanged → delta จาก input.Position ที่เก็บไว้ (same coordinate space)
    --   ไม่มี coordinate mismatch ทั้งสิ้น
    -- ──────────────────────────────────────────────────────────

    -- ยก ZIndex ของ dots ให้สูงกว่า TopBar (ZIndex=10)
    RedDot.ZIndex    = 15
    YellowDot.ZIndex = 15

    local TopBar = Instance.new("TextButton", MainFrame)
    TopBar.Name                = "TopBar"
    TopBar.Size                = UDim2.new(1, 0, 0, 40)
    TopBar.Position            = UDim2.new(0, 0, 0, 0)
    TopBar.BackgroundTransparency = 1
    TopBar.Text                = ""
    TopBar.ZIndex              = 10
    TopBar.AutoButtonColor     = false

    -- MouseEnter/MouseLeave ไม่ต้องคำนวณตำแหน่งเลย — Roblox จัดการให้เอง
    TopBar.MouseEnter:Connect(function() mouseOverTopBar = true  end)
    TopBar.MouseLeave:Connect(function() mouseOverTopBar = false end)

    local dragBeginConn = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1
        and input.UserInputType ~= Enum.UserInputType.Touch then return end
        if not mouseOverTopBar then return end
        dragging      = true
        dragStartPos  = input.Position
        frameStartPos = MainFrame.Position
    end)
    table.insert(BottleLib.Connections, dragBeginConn)

    local dragEndConn = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    table.insert(BottleLib.Connections, dragEndConn)

    -- delta = input.Position - dragStartPos (Vector3 arithmetic, same UIS space ทั้งคู่)
    -- ไม่ต้อง AbsolutePosition, ไม่ต้อง GetMouseLocation()
    local dragMoveConn = UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement
        and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local dx = input.Position.X - dragStartPos.X
        local dy = input.Position.Y - dragStartPos.Y
        MainFrame.Position = UDim2.new(
            frameStartPos.X.Scale, frameStartPos.X.Offset + dx,
            frameStartPos.Y.Scale, frameStartPos.Y.Offset + dy
        )
    end)
    table.insert(BottleLib.Connections, dragMoveConn)

    local SbTitle = Instance.new("TextLabel", Sidebar)
    SbTitle.Text = HubName; SbTitle.Size = UDim2.new(1,0,0,36)
    SbTitle.Position = UDim2.new(0,-6,0,36); SbTitle.BackgroundTransparency = 1
    SbTitle.TextColor3 = T.Accent; SbTitle.Font = Enum.Font.GothamBlack; SbTitle.TextSize = 15

    local WindowObj = {}
    WindowObj.ActiveDropdown = nil

    local GlobalOverlayClose = Instance.new("TextButton", ScreenGui)
    GlobalOverlayClose.Size = UDim2.new(1,0,1,0); GlobalOverlayClose.BackgroundTransparency = 1
    GlobalOverlayClose.Text = ""; GlobalOverlayClose.ZIndex = 79; GlobalOverlayClose.Visible = false
    GlobalOverlayClose.MouseButton1Click:Connect(function()
        if WindowObj.ActiveDropdown then
            WindowObj.ActiveDropdown.Visible = false
            WindowObj.ActiveDropdown = nil
        end
        GlobalOverlayClose.Visible = false
    end)

    local PROFILE_H = 135
