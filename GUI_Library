-- 🔴 [Fix 1: SpawnLocation Caching System]
local cachedSpawnLocations = {}
local function RebuildSpawnCache()
    table.clear(cachedSpawnLocations)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("SpawnLocation") then table.insert(cachedSpawnLocations, obj) end
    end
end
RebuildSpawnCache()
table.insert(Connections, workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("SpawnLocation") then table.insert(cachedSpawnLocations, obj) end
end))

local function IsSafeZone(pos)
    -- เช็คจาก Cache ล้วนๆ (กินทรัพยากรน้อยมาก)
    for _, obj in ipairs(cachedSpawnLocations) do
        if obj and obj.Parent and (pos - obj.Position).Magnitude < 40 then return true end
    end
    -- Fallback กรณีไม่มี SpawnLocation แต่มี Baseplate
    local bp = workspace:FindFirstChild("Spawn") and workspace.Spawn:FindFirstChild("Baseplate") 
            or workspace:FindFirstChild("Baseplate") or workspace:FindFirstChild("SpawnPlate")
    if bp and bp:IsA("BasePart") then
        local r = bp.CFrame:PointToObjectSpace(pos); local h = bp.Size / 2
        if math.abs(r.X) <= h.X+2 and math.abs(r.Z) <= h.Z+2 and r.Y >= -(h.Y+10) and r.Y <= (h.Y+100) then return true end
    end
    return false
end

