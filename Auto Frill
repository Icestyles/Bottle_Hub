-- OPTIMIZE OBJECT (FIXED: Map Flashing & Player Fade)
-- ==========================================
local function OptimizeObject(v)
    if not ReduceLagEnabled then return end
    if v.Parent and (v.Parent:FindFirstChild("Humanoid") or (v.Parent.Parent and v.Parent.Parent:FindFirstChild("Humanoid"))) then return end

    local arena = workspace:FindFirstChild("Frill Arena")
    if arena then
        local tiles = arena:FindFirstChild("FragileTiles")
        if tiles and v:IsDescendantOf(tiles) then return end
    end

    if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
        v.Enabled = false
    elseif v:IsA("Explosion") then
        v.Visible = false
        v.BlastPressure = 0
        v.BlastRadius = 0
    elseif v:IsA("PostEffect") or v:IsA("Light") then
        v.Enabled = false
    elseif v:IsA("Decal") or v:IsA("Texture") then
        if v.Transparency ~= 1 then v.Transparency = 1 end
    elseif v:IsA("BasePart") or v:IsA("MeshPart") then
        if v.Material ~= Enum.Material.SmoothPlastic then v.Material = Enum.Material.SmoothPlastic end
        v.Reflectance = 0
        v.CastShadow = false
        if v:IsA("Part") and v.Shape == Enum.PartType.Ball then
            if v.Transparency < 0.8 then v.Transparency = 0.8 end
        elseif not v.CanCollide then
            if v.Transparency < 0.8 then v.Transparency = 0.8 end
        end
        if v:IsA("MeshPart") then v.TextureID = "" end
    end
end

local function ApplyRenderSetting(level)
    local quality = Enum.QualityLevel.Level01 
    if level == 1 then quality = Enum.QualityLevel.Level01
    elseif level == 2 then quality = Enum.QualityLevel.Level06
    elseif level == 3 then quality = Enum.QualityLevel.Level10
    elseif level == 4 then quality = Enum.QualityLevel.Level16
    elseif level == 5 then quality = Enum.QualityLevel.Level21 end
    
    pcall(function() settings().Rendering.QualityLevel = quality end)
    
    if Lighting then
        Lighting.GlobalShadows = false
        Lighting.FogStart = 100000 
        Lighting.FogEnd = 100000
    end
    
    if ReduceLagEnabled then
        for _, v in pairs(workspace:GetDescendants()) do OptimizeObject(v) end
    end
end

local function ToggleReduceLag(enable)
    ReduceLagEnabled = enable
    if enable then
        if Lighting then Lighting.GlobalShadows = false Lighting.Brightness = 2 end
        ApplyRenderSetting(CurrentGraphicLevel)
        if LagMonitorConnection then LagMonitorConnection:Disconnect() end
        LagMonitorConnection = workspace.DescendantAdded:Connect(OptimizeObject)
        print("FPS Boost Active")
    else
        if LagMonitorConnection then LagMonitorConnection:Disconnect() LagMonitorConnection = nil end
        if Lighting then Lighting.GlobalShadows = true end
        ApplyRenderSetting(5)
        settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
        print("FPS Boost Disabled")
    end
end

-- Core Logic Functions
local function PressKey(key)
    if not key then return end
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode[key], false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode[key], false, game)
end

local function ClickMouse()
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
end

local function HoldMouse(duration)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    task.wait(duration)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
end

-- ESP SYSTEM
local function UpdateESP()
    if not ESPEnabled then return end
    local function ApplyHighlight(model, color)
        if not model then return end
        if not model:FindFirstChild("FarmHighlight") then
            local highlight = Instance.new("Highlight")
            highlight.Name = "FarmHighlight"
            highlight.Adornee = model
            highlight.FillColor = color
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.FillTransparency = 0.5
            highlight.OutlineTransparency = 0
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.Parent = model
        end
    end
    for _, child in pairs(MobFolder:GetChildren()) do
        if child.Name == "Frill" then ApplyHighlight(child, Color3.fromRGB(255, 0, 0)) 
        elseif child.Name == "Puppet" then
             local extras = child:FindFirstChild("Extras")
             if extras and extras:FindFirstChild("FrillScythe") then ApplyHighlight(child, Color3.fromRGB(255, 170, 0)) end
        end
    end
end

local function ClearESP()
    for _, v in pairs(MobFolder:GetDescendants()) do if v.Name == "FarmHighlight" then v:Destroy() end end
end

local function ToggleESP(enable)
    ESPEnabled = enable
    if enable then
        if ESPConnection then ESPConnection:Disconnect() end
        ESPConnection = RunService.Stepped:Connect(function() if tick() % 1 < 0.1 then UpdateESP() end end)
        UpdateESP()
    else
        if ESPConnection then ESPConnection:Disconnect() ESPConnection = nil end
        ClearESP()
    end
end

