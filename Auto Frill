local function GetTargetHealth(target)
    if not target then return nil end
    local parent = target.Parent
    if parent.Name == "Frill" or parent.Name == "Puppet" then
        local enemy = parent:FindFirstChild("Enemy")
        if enemy then
            local healthValue = enemy:FindFirstChild("HealthValue")
            if healthValue then return math.floor(healthValue.Value) end
        end
    end
    return nil
end

local function GetTargetMaxHealth(target)
    if not target then return 100 end
    local parent = target.Parent
    if parent.Name == "Frill" or parent.Name == "Puppet" then
        local enemy = parent:FindFirstChild("Enemy")
        if enemy then
            local maxHealthValue = enemy:FindFirstChild("MaxHealthValue")
            if maxHealthValue then return math.floor(maxHealthValue.Value) end
        end
    end
    return 100
end

-- [CHANGED] TweenToTarget: Now positions at Side and looks at target
local function TweenToTarget(target)
    if not target or not LocalPlayer.Character then return end
    local humanoidRootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end
    if TweenConnection then TweenConnection:Disconnect() TweenConnection = nil end
    
    local tweenInfo = TweenInfo.new(TweenSpeed, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, 0, false, 0)
    local goal = {}
    
    -- [NEW LOGIC] Calculate Side Position + Height
    local offset = Vector3.new(SideDistance, AttackHeight, 0) -- X = Side, Y = Height
    local targetPos = target.Position
    local finalPos = targetPos + offset
    
    -- Look at the target (CFrame.lookAt)
    goal.CFrame = CFrame.lookAt(finalPos, targetPos)
    
    local tween = TweenService:Create(humanoidRootPart, tweenInfo, goal)
    tween:Play()
    
    local lastTweenUpdate = tick()
    TweenConnection = RunService.Heartbeat:Connect(function()
        if not target or not target.Parent or not AutoFarmEnabled then
            if TweenConnection then TweenConnection:Disconnect() TweenConnection = nil end
            return
        end
        
        if humanoidRootPart then
            humanoidRootPart.Velocity = Vector3.new(0, 0, 0)
            humanoidRootPart.RotVelocity = Vector3.new(0, 0, 0)
        end
        
        local currentTime = tick()
        if currentTime - lastTweenUpdate < 0.05 then return end
        lastTweenUpdate = currentTime
        
        -- Update dynamic position
        targetPos = target.Position
        finalPos = targetPos + Vector3.new(SideDistance, AttackHeight, 0)
        
        goal.CFrame = CFrame.lookAt(finalPos, targetPos)
        
        tween = TweenService:Create(humanoidRootPart, tweenInfo, goal)
        tween:Play()
    end)
end

