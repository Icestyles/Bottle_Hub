    if ESPButton then ESPButton.MouseButton1Click:Connect(OnESPToggle) end
    
    local LagContainer = Content and Content:FindFirstChild("LagContainer")
    local LagButton = LagContainer and LagContainer:FindFirstChild("LagButton")
    if LagButton then LagButton.MouseButton1Click:Connect(OnLagToggle) end
    
