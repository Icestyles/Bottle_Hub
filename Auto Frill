-- UI Helpers
local function MakeRounded(guiObject, radius)
    local uiCorner = Instance.new("UICorner")
    uiCorner.CornerRadius = UDim.new(0, radius or 10)
    uiCorner.Parent = guiObject
    return uiCorner
end

local function AddStroke(guiObject, color, transparency, thickness)
    local uiStroke = Instance.new("UIStroke")
    uiStroke.Color = color or Color3.fromRGB(255, 255, 255)
    uiStroke.Transparency = transparency or 0.8
    uiStroke.Thickness = thickness or 1
    uiStroke.Parent = guiObject
    return uiStroke
end

