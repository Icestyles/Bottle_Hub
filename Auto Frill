    local CloseButton = TitleBar and TitleBar:FindFirstChild("CloseButton")
    if CloseButton then
        CloseButton.MouseButton1Click:Connect(function()
            AutoFarmEnabled = false
            ToggleESP(false)
            ToggleFeatures(false)
            if TweenConnection then TweenConnection:Disconnect() TweenConnection = nil end
            GUI:Destroy()
            GUI = nil
            script:Destroy()
        end)
    end
    
    -- [UPDATED] Vertical Distance Input Logic
    local VDistFrame = Content and Content:FindFirstChild("VDistFrame")
    local VInputBg = VDistFrame and VDistFrame:FindFirstChild("Frame")
    local VDistInput = VInputBg and VInputBg:FindFirstChild("VDistInput")
    if VDistInput then
        local function UpdateVDistance()
            local newHeight = tonumber(VDistInput.Text)
            if newHeight and newHeight >= 1 and newHeight <= 100 then
                AttackHeight = newHeight
                if AutoFarmEnabled and CurrentTarget then TweenToTarget(CurrentTarget) end
            else
                VDistInput.Text = tostring(AttackHeight)
            end
        end
        VDistInput.FocusLost:Connect(UpdateVDistance)
    end

    -- [NEW] Side Distance Input Logic
    local SDistFrame = Content and Content:FindFirstChild("SDistFrame")
    local SInputBg = SDistFrame and SDistFrame:FindFirstChild("Frame")
    local SDistInput = SInputBg and SInputBg:FindFirstChild("SDistInput")
    if SDistInput then
        local function UpdateSDistance()
            local newSide = tonumber(SDistInput.Text)
            if newSide and newSide >= 1 and newSide <= 100 then
                SideDistance = newSide
                if AutoFarmEnabled and CurrentTarget then TweenToTarget(CurrentTarget) end
            else
                SDistInput.Text = tostring(SideDistance)
            end
        end
        SDistInput.FocusLost:Connect(UpdateSDistance)
    end
    
    -- Slider Logic
    local ViewFrame = Content:FindFirstChild("ViewFrame")
    if ViewFrame then
        local SliderTrack = ViewFrame:FindFirstChild("SliderTrack")
        local SliderKnob = SliderTrack and SliderTrack:FindFirstChild("SliderKnob")
        local SliderFill = SliderTrack and SliderTrack:FindFirstChild("SliderFill")
        local ViewTitle = ViewFrame:FindFirstChild("ViewTitle")
        
        if SliderKnob and SliderTrack then
            local isDragging = false
            local function UpdateSlider(input)
                local pos = input.Position.X
                local trackPos = SliderTrack.AbsolutePosition.X
                local trackSize = SliderTrack.AbsoluteSize.X
                local relativePos = math.clamp((pos - trackPos) / trackSize, 0, 1)
                
                SliderKnob.Position = UDim2.new(relativePos, -8, 0.5, -8)
                SliderFill.Size = UDim2.new(relativePos, 0, 1, 0)
                
                local level = 1 + (relativePos * 4)
                local displayLevel = math.floor(level + 0.5) 
                
                if displayLevel ~= CurrentGraphicLevel then
                    CurrentGraphicLevel = displayLevel
                    ViewTitle.Text = "Render Distance: Level " .. displayLevel
                    if ReduceLagEnabled then ApplyRenderSetting(CurrentGraphicLevel) end
                end
            end
            
            SliderKnob.MouseButton1Down:Connect(function() isDragging = true end)
            UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then isDragging = false end end)
            UserInputService.InputChanged:Connect(function(input) if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then UpdateSlider(input) end end)
        end
    end
    
    -- Weapon Slot Updates
    local WeaponFrame = Content:FindFirstChild("WeaponFrame")
    if WeaponFrame then
        for i = 1, 4 do
            local SlotBg = WeaponFrame:FindFirstChild("SlotBg"..i)
            local SlotInput = SlotBg and SlotBg:FindFirstChild("Slot"..i)
            if SlotInput then
                SlotInput:GetPropertyChangedSignal("Text"):Connect(function()
                    local key = NumberKeys[SlotInput.Text]
                    WeaponSlots[i] = key 
                end)
            end
        end
    end
    
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed then
            if input.KeyCode == Enum.KeyCode.LeftControl then
                if GUI then GUI.Enabled = not GUI.Enabled end
            elseif input.KeyCode == Enum.KeyCode.Y then
                ToggleAutoFarm()
            end
        end
    end)
    
    print("Auto Farm V26 - Side Attack Position Update")
end

