-- [CORE FUNCTIONS: AUTO FARM LOGIC]

local function FindPuppetWithScythe()
    local children = MobFolder:GetChildren()
    for i = 1, #children do
        local child = children[i]
        if child.Name == "Puppet" then
            local extras = child:FindFirstChild("Extras")
            if extras then
                local frillScythe = extras:FindFirstChild("FrillScythe")
                if frillScythe then
                    local hurtBox = child:FindFirstChild("HurtBox")
                    if hurtBox then
                        TargetPriority = "Puppet (With Scythe)"
                        return hurtBox
                    end
                end
            end
        end
    end
    return nil
end

local function FindTarget()
    local puppetTarget = FindPuppetWithScythe()
    if puppetTarget then return puppetTarget end
    local frill = MobFolder:FindFirstChild("Frill")
    if frill and frill:FindFirstChild("HurtBox") then
        local currentTime = tick()
        if FrillSpawnTime == 0 then
            FrillSpawnTime = currentTime
            IsWaitingForFrill = true
            FrillWaitTimer = 2
            print("New Frill detected! Waiting 2 seconds...")
            return nil
        elseif IsWaitingForFrill then
            local timeSinceSpawn = currentTime - FrillSpawnTime
            if timeSinceSpawn >= FrillWaitTimer then
                IsWaitingForFrill = false
                TargetPriority = "Frill"
                print("Frill wait complete! Targeting Frill.")
                return frill.HurtBox
            else
                if GUI and GUI:FindFirstChild("MainFrame") then
                    local StatusCard = GUI.MainFrame:FindFirstChild("Content") and GUI.MainFrame.Content:FindFirstChild("StatusCard")
                    local TargetLabel = StatusCard and StatusCard:FindFirstChild("TargetLabel")
                    if TargetLabel then
                        local remaining = math.ceil(FrillWaitTimer - timeSinceSpawn)
                        TargetLabel.Text = "Waiting: " .. remaining .. "s"
                    end
                end
                return nil
            end
        else
            TargetPriority = "Frill"
            return frill.HurtBox
        end
    else
        FrillSpawnTime = 0
        IsWaitingForFrill = false
    end
    return nil
end

local function EnableFly()
