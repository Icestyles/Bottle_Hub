local function PerformDynamicLoop(ModeName)
    UpdateWeaponSlots()
    
    local activeWeaponsCount = 0
    for i = 1, 4 do
        if WeaponSlots[i] then activeWeaponsCount = activeWeaponsCount + 1 end
    end
    
    local baseCycleTime = 12 
    local timePerStage = 2
    local autoAttackDuration = baseCycleTime - (activeWeaponsCount * timePerStage)
    if autoAttackDuration < 1 then autoAttackDuration = 1 end
    
    if IsFirstLoop then
        if WeaponSlots[1] then
            PressKey(WeaponSlots[1])
            CurrentEquippedKey = WeaponSlots[1]
            UpdateWeaponLabel("Mode: " .. ModeName .. "\nEquipping Main Weapon")
            task.wait(0.5)
        end
        IsFirstLoop = false
    end
    
    for i = 1, 4 do
        local key = WeaponSlots[i]
        if key then
            if not WeaponRotationRunning or not AutoFarmEnabled or CurrentPattern ~= ModeName then return end
            
            if CurrentEquippedKey ~= key then
                PressKey(key)
                CurrentEquippedKey = key
                UpdateWeaponLabel("Mode: " .. ModeName .. "\nSwitching to Weapon " .. i)
                task.wait(0.5) 
            else
                UpdateWeaponLabel("Mode: " .. ModeName .. "\nWeapon " .. i .. " Active")
                task.wait(0.1) 
            end

            for _, skill in pairs(SkillOrder) do
                if not WeaponRotationRunning or not AutoFarmEnabled then break end
                PressKey(skill)
                task.wait(0.1)
            end
            
            if i > 1 then
                HoldMouse(0.3) 
            end
            
            task.wait(0.5)
        end
    end
    
    if WeaponSlots[1] then
        if not WeaponRotationRunning or not AutoFarmEnabled or CurrentPattern ~= ModeName then return end
        
        local mainKey = WeaponSlots[1]
        if CurrentEquippedKey ~= mainKey then
            PressKey(mainKey)
            CurrentEquippedKey = mainKey
            task.wait(0.5)
        end
        
        UpdateWeaponLabel("Mode: " .. ModeName .. "\nAuto Atk: " .. autoAttackDuration .. "s")
        
        local timer = 0
        while timer < autoAttackDuration and WeaponRotationRunning and AutoFarmEnabled and CurrentPattern == ModeName do
            ClickMouse()
            task.wait(0.1)
            timer = timer + 0.1
        end
    end
end

local function DefaultWeaponRotation()
    PerformDynamicLoop("Default")
end

local function SpecialWeaponRotation()
    PerformDynamicLoop("Special")
end

local function WeaponRotationLoop()
    IsFirstLoop = true
    CurrentEquippedKey = nil
    
    while WeaponRotationRunning and AutoFarmEnabled do
        if CurrentPattern ~= "Default" then
            CurrentPattern = "Default"
            IsFirstLoop = true
        end
        DefaultWeaponRotation()
        task.wait(0.1)
    end
    
    UpdateWeaponSlots()
    if WeaponSlots[1] then
        PressKey(WeaponSlots[1])
    end
    IsFirstLoop = true
    CurrentPattern = "Default"
end

local function AutoFarmLoop()
    while AutoFarmEnabled do
        local currentTime = tick()
        if currentTime - LastTargetUpdate >= TargetUpdateInterval then
            LastTargetUpdate = currentTime
            local target = FindTarget()
            if target then
                CurrentTarget = target
                if currentTime - LastUIUpdate >= UIUpdateInterval then
                    LastUIUpdate = currentTime
                    if GUI and GUI:FindFirstChild("MainFrame") then
                        local StatusCard = GUI.MainFrame:FindFirstChild("Content") and GUI.MainFrame.Content:FindFirstChild("StatusCard")
                        local TargetLabel = StatusCard and StatusCard:FindFirstChild("TargetLabel")
                        if TargetLabel then TargetLabel.Text = "Target: " .. TargetPriority end
                    end
                end
                
                TweenToTarget(target)
                
                if not WeaponRotationRunning then 
                    WeaponRotationRunning = true 
                    UpdateWeaponSlots()
                    
                    if WeaponSlots[1] then
                        PressKey(WeaponSlots[1])
                        CurrentEquippedKey = WeaponSlots[1]
                        task.wait(0.5)
                    end
                    task.spawn(WeaponRotationLoop) 
                end
                if not SkillCycleRunning then 
                    SkillCycleRunning = true 
                    task.spawn(SkillRotation) 
                end
                if not AttackLoopRunning then 
                    AttackLoopRunning = true 
                    task.spawn(AutoAttack) 
                end
                
                if currentTime - LastHealthUpdate >= HealthUpdateInterval then
                    LastHealthUpdate = currentTime
                    if GUI and GUI:FindFirstChild("MainFrame") then
                        local StatusCard = GUI.MainFrame:FindFirstChild("Content") and GUI.MainFrame.Content:FindFirstChild("StatusCard")
                        local HealthLabel = StatusCard and StatusCard:FindFirstChild("HealthLabel")
                        local HealthBarBG = StatusCard and StatusCard:FindFirstChild("HealthBarBG")
                        local HealthBar = HealthBarBG and HealthBarBG:FindFirstChild("HealthBar")
                        
                        if HealthLabel then
                            local health = GetTargetHealth(target)
                            local maxHealth = GetTargetMaxHealth(target)
                            if health then
                                local percentage = math.floor((health / maxHealth) * 100)
                                HealthLabel.Text = "Health: " .. health .. "/" .. maxHealth
                                if HealthBar then
                                    HealthBar.Size = UDim2.new(percentage / 100, 0, 1, 0)
                                    if percentage > 50 then HealthBar.BackgroundColor3 = Color3.fromRGB(48, 209, 88)
                                    elseif percentage > 20 then HealthBar.BackgroundColor3 = Color3.fromRGB(255, 204, 0)
                                    else HealthBar.BackgroundColor3 = Color3.fromRGB(255, 59, 48)
                                    end
                                end
                            else
                                HealthLabel.Text = "Health: N/A"
                                if HealthBar then HealthBar.Size = UDim2.new(0, 0, 1, 0) end
                            end
                        end
                    end
                end
            else
                CurrentTarget = nil
                if TweenConnection then TweenConnection:Disconnect() TweenConnection = nil end
                SkillCycleRunning = false
                AttackLoopRunning = false
                WeaponRotationRunning = false
                if currentTime - LastUIUpdate >= UIUpdateInterval then
                    LastUIUpdate = currentTime
                    if GUI and GUI:FindFirstChild("MainFrame") then
                        local StatusCard = GUI.MainFrame:FindFirstChild("Content") and GUI.MainFrame.Content:FindFirstChild("StatusCard")
                        local TargetLabel = StatusCard and StatusCard:FindFirstChild("TargetLabel")
                        local HealthLabel = StatusCard and StatusCard:FindFirstChild("HealthLabel")
                        local HealthBarBG = StatusCard and StatusCard:FindFirstChild("HealthBarBG")
                        local HealthBar = HealthBarBG and HealthBarBG:FindFirstChild("HealthBar")
                        local InfoCard = GUI.MainFrame.Content:FindFirstChild("InfoCard")
                        local WeaponLabel = InfoCard and InfoCard:FindFirstChild("WeaponLabel")
                        
                        if TargetLabel then TargetLabel.Text = "Target: None" end
                        if HealthLabel then HealthLabel.Text = "Health: N/A" end
                        if HealthBar then HealthBar.Size = UDim2.new(0, 0, 1, 0) end
                        if WeaponLabel then WeaponLabel.Text = "Weapon: Ready\nMode: Waiting" end
                    end
                end
            end
        end
        task.wait(0.2)
    end
    
    if TweenConnection then TweenConnection:Disconnect() TweenConnection = nil end
    SkillCycleRunning = false
    AttackLoopRunning = false
    WeaponRotationRunning = false
    CurrentTarget = nil
end

