            RemoveStoredKey(); VerifyBtn.Text = "Key Expired"; VerifyBtn.BackgroundColor3 = Color3.fromRGB(231,76,60); task.spawn(ShakeMF)
            task.delay(1.5, function() if player then player:Kick(("BottleHub: %s had expired"):format(input)) end end)
        else
            VerifyBtn.Text = "Invalid Key"; VerifyBtn.BackgroundColor3 = Color3.fromRGB(231,76,60); task.spawn(ShakeMF); task.wait(1.5)
            VerifyBtn.Text = "Verify"; VerifyBtn.BackgroundColor3 = Color3.fromHex("#e60852")
        end
    end)

    VerifyEvent.Event:Wait()
    return true
end

