-- @description Returns the decoded backend URL for external script usage.
function BottleLib:GetBackendURL()
    return GetGasEndpoint()
end

-- @description Safely retrieves the user's Hardware ID (HWID) across multiple executors.
function BottleLib:GetHWID()
    if type(gethwid) == "function" then
        local ok, hwid = pcall(gethwid); if ok and hwid and hwid ~= "" then return hwid end
    end
    local ok, id = pcall(function() return RbxAnalyticsService:GetClientId() end)
    if ok and id and id ~= "" then return id end
    
    local HWID_FILE = "BottleHub_LocalHWID.txt"
    if isfile and isfile(HWID_FILE) and readfile then
        local rOk, saved = pcall(readfile, HWID_FILE); if rOk and type(saved) == "string" and saved ~= "" then return saved end
    end
    local newHwid = "FALLBACK-" .. HttpService:GenerateGUID(false)
    if writefile then pcall(writefile, HWID_FILE, newHwid) end
    return newHwid
end

-- @description Sends usage statistics to the GAS backend silently.
-- @param scriptName (string): The name of the script currently being executed.
-- 📊 ฟังก์ชันหลักสำหรับส่งสถิติ (Analytics) ไปยัง GAS
function BottleLib:SendAnalytics(scriptName)
    task.spawn(function()
        local url = self:GetBackendURL()
        
        -- 🟢 ดึงชื่อเกมจาก MarketplaceService 
        local ok, info = pcall(function() return MarketplaceService:GetProductInfo(game.PlaceId) end)
        local gameName = ok and info.Name or game.Name
        -- นำชื่อเกมมาประกอบกับ ID เผื่อไว้ (เช่น "Blox Fruits (2753915549)")
        local formattedPlace = gameName .. " (" .. tostring(game.PlaceId) .. ")"
        
        local payload = {
            action = "log_stats",
            hwid = self:GetHWID(),
            placeId = formattedPlace, -- 🟢 ส่งชื่อเกมไปแทน
            script = scriptName or "Unknown",
            key = self.KeyStatus.KeyName or "Unknown",
            tier = self.KeyStatus.Tier or "Basic"
        }
        
        local req = (syn and syn.request) or (http and http.request) or http_request or request
        if req then
            pcall(function()
                req({
                    Url = url,
                    Method = "POST",
                    Body = HttpService:JSONEncode(payload),
                    Headers = {["Content-Type"] = "application/json"}
                })
            end)
        end
    end)
end

