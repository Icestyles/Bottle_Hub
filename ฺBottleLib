    local MFStroke = Instance.new("UIStroke", MainFrame)
    MFStroke.Color = T.Accent; MFStroke.Thickness = 1.5

    TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.new(0,660,0,520), Position = UDim2.new(0.5,-330,0.5,-260)
    }):Play()

    local dragStrip = Instance.new("TextButton", MainFrame)
    dragStrip.Name               = "DragStrip"
    dragStrip.Size               = UDim2.new(0, 195, 1, 0)
    dragStrip.Position           = UDim2.new(0, 0, 0, 0)
    dragStrip.BackgroundTransparency = 1; dragStrip.Text = ""; dragStrip.ZIndex = 2; dragStrip.AutoButtonColor = false

    local DRAG_THRESHOLD = 6   
    local isMouseDown, isDragging = false, false
    local dragStartX, dragStartY, dragOffsetX, dragOffsetY = 0, 0, 0, 0

    dragStrip.MouseButton1Down:Connect(function(x, y)
        isMouseDown = true; isDragging  = false
        dragStartX  = x; dragStartY  = y
        dragOffsetX = MainFrame.Position.X.Offset; dragOffsetY = MainFrame.Position.Y.Offset
    end)

    dragStrip.MouseMoved:Connect(function(x, y)
        if not isMouseDown then return end
        local dx = x - dragStartX; local dy = y - dragStartY
        if not isDragging then
            if math.abs(dx) > DRAG_THRESHOLD or math.abs(dy) > DRAG_THRESHOLD then isDragging = true else return end
        end
        MainFrame.Position = UDim2.new(MainFrame.Position.X.Scale, dragOffsetX + dx, MainFrame.Position.Y.Scale, dragOffsetY + dy)
    end)
    dragStrip.MouseButton1Up:Connect(function() isMouseDown = false; isDragging  = false end)

    local MiniButton = Instance.new("ImageButton", ScreenGui)
    MiniButton.Size = UDim2.new(0,42,0,42); MiniButton.Position = UDim2.new(0,10,0,10)
