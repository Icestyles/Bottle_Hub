function BottleLib:InitKeySystem()
    local KEY_STORAGE_FILE = "BottleHub_KeyStorage.json"

    local function GetHWID()
        if type(gethwid) == "function" then
            local ok, hwid = pcall(gethwid); if ok and hwid and hwid ~= "" then return hwid end
        end
        local ok, id = pcall(function() return RbxAnalyticsService:GetClientId() end)
        if ok and id and id ~= "" then return id end
        local HWID_FILE = "BottleHub_LocalHWID.txt"
        if isfile and isfile(HWID_FILE) and readfile then
            local rOk, saved = pcall(readfile, HWID_FILE); if rOk and type(saved) == "string" and saved ~= "" then return saved end
        end
        local newHwid = "FALLBACK-" .. HttpService:GenerateGUID(false)
        if writefile then pcall(writefile, HWID_FILE, newHwid) end
        return newHwid
    end

    local function MakeRequest(url)
        local fn = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
        if not fn then return nil, "Executor not supported" end
        local ok, res = pcall(function() return fn({ Url = url, Method = "GET" }) end)
        if not ok then return nil, "HTTP Call Failed" end
        return res
    end

    local function CheckCloudVIP()
        local url = string.format("%s?action=check_vip&userId=%s", SECRETS.GAS_URL, tostring(player.UserId))
        local res = MakeRequest(url)
        if res and res.Body then
            local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
            if ok and type(data) == "table" and data.vip == true then return true end
        end
        return false
    end

    local function VerifyKeyWithServer(key)
        local url = string.format("%s?action=verify_key&key=%s&hwid=%s&placeId=%s", SECRETS.GAS_URL, key, GetHWID(), tostring(game.PlaceId))
        local res, err = MakeRequest(url)
        if res and res.Body then
            local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
            if ok and type(data) == "table" then
                -- 🔴 ดึง accessLevel มาจากเซิร์ฟเวอร์
                return data.valid == true, data.expired == true, data.message or "", data.expirationTime or nil, data.isGlobal == true, data.accessLevel or "Basic"
            end
            return false, false, "Invalid JSON", nil, false, "Basic"
        end
        return false, false, err or "Timeout", nil, false, "Basic"
    end

    local function LoadStoredKey()
        if not isfile or not readfile then return nil end
        if not isfile(KEY_STORAGE_FILE) then return nil end
        local ok, raw = pcall(readfile, KEY_STORAGE_FILE)
        local ok2, d  = pcall(function() return HttpService:JSONDecode(raw) end)
        if ok2 and type(d) == "table" and d.key and d.hwid then return d end
        return nil
    end

    local function SaveKey(key, expTime)
        if not writefile then return false end
        local d = { key=key, hwid=GetHWID(), timestamp=os.time(), expiresAt=expTime }
        pcall(function() writefile(KEY_STORAGE_FILE, HttpService:JSONEncode(d)) end)
    end

    local function RemoveStoredKey() pcall(function() delfile(KEY_STORAGE_FILE) end) end

    if CheckCloudVIP() then
        BottleLib.KeyStatus = { Valid=true, ExpiresAt=nil, IsGlobal=true, Tier="Full" }
        print("[BottleHub] VIP Access Granted via Cloud!")
        return true
    end

    local d = LoadStoredKey()
    if d and d.hwid == GetHWID() then
        if d.expiresAt and type(d.expiresAt) == "number" and os.time() >= d.expiresAt then
            RemoveStoredKey(); player:Kick("BottleHub: Your saved key has expired."); return false
        end
        local isValid, isExpired, _, expTime, isGlobal, tier = VerifyKeyWithServer(d.key)
        if isValid and not isExpired then
            BottleLib.KeyStatus = { Valid=true, ExpiresAt=tonumber(expTime), IsGlobal=isGlobal, Tier=tier or "Basic" }
            return true
        end
        RemoveStoredKey()
        if isExpired then player:Kick("BottleHub: Key Expired"); return false end
    end

    local VerifyEvent = Instance.new("BindableEvent")
    if CoreGui:FindFirstChild("BOTTLEHUB_KEY_SYSTEM") then CoreGui.BOTTLEHUB_KEY_SYSTEM:Destroy() end
    local KeyScreen = Instance.new("ScreenGui"); KeyScreen.Name = "BOTTLEHUB_KEY_SYSTEM"; KeyScreen.Parent = (gethui and gethui()) or CoreGui

    local MF = Instance.new("Frame", KeyScreen)
    MF.Size = UDim2.new(0,380,0,200); MF.Position = UDim2.new(0.5,-190,0.5,-100)
    MF.BackgroundColor3 = Color3.fromRGB(12,12,12); MF.Active = true; MF.Draggable = true
    Instance.new("UICorner", MF).CornerRadius = UDim.new(0, 12); Instance.new("UIStroke", MF).Color = Color3.fromRGB(35,35,35)
    TweenService:Create(MF, TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { Size=UDim2.new(0,400,0,220), Position=UDim2.new(0.5,-200,0.5,-110) }):Play()

    local CloseBtn = Instance.new("TextButton", MF)
    CloseBtn.Size=UDim2.new(0,14,0,14); CloseBtn.Position=UDim2.new(0,15,0,15); CloseBtn.BackgroundColor3=Color3.fromRGB(255,75,75); CloseBtn.Text=""
    Instance.new("UICorner", CloseBtn).CornerRadius=UDim.new(1,0); CloseBtn.MouseButton1Click:Connect(function() KeyScreen:Destroy() end)

    local Title = Instance.new("TextLabel", MF)
    Title.Text='Bottle<font color="#e60852">Hub</font>'; Title.RichText=true; Title.Size=UDim2.new(1,-60,0,20); Title.Position=UDim2.new(0,30,0,12)
    Title.BackgroundTransparency=1; Title.TextColor3=Color3.fromRGB(255,255,255); Title.Font=Enum.Font.GothamBold; Title.TextSize=16

    local InputBg = Instance.new("Frame", MF)
    InputBg.Size=UDim2.new(1,-50,0,45); InputBg.Position=UDim2.new(0,25,0,65); InputBg.BackgroundColor3=Color3.fromRGB(20,20,20)
    Instance.new("UICorner", InputBg).CornerRadius=UDim.new(0,8); local InputStr = Instance.new("UIStroke", InputBg); InputStr.Color=Color3.fromRGB(40,40,40); InputStr.Thickness=1

    local InputBox = Instance.new("TextBox", InputBg)
    InputBox.Size=UDim2.new(1,-24,1,0); InputBox.Position=UDim2.new(0,12,0,0); InputBox.BackgroundTransparency=1; InputBox.Text=""
    InputBox.ClearTextOnFocus=false; InputBox.PlaceholderText="Enter License Key"; InputBox.TextColor3=Color3.fromRGB(240,240,240)
    InputBox.Font=Enum.Font.GothamMedium; InputBox.TextSize=14
    InputBox.Focused:Connect(function() TweenService:Create(InputStr,TweenInfo.new(0.3),{Color=Color3.fromHex("#e60852")}):Play(); TweenService:Create(InputBg,TweenInfo.new(0.3),{BackgroundColor3=Color3.fromRGB(25,25,25)}):Play() end)
    InputBox.FocusLost:Connect(function() TweenService:Create(InputStr,TweenInfo.new(0.3),{Color=Color3.fromRGB(40,40,40)}):Play(); TweenService:Create(InputBg,TweenInfo.new(0.3),{BackgroundColor3=Color3.fromRGB(20,20,20)}):Play() end)

    local VerifyBtn = Instance.new("TextButton", MF)
    VerifyBtn.Size=UDim2.new(1,-50,0,40); VerifyBtn.Position=UDim2.new(0,25,0,125); VerifyBtn.BackgroundColor3=Color3.fromHex("#e60852"); VerifyBtn.Text="Verify"
    VerifyBtn.TextColor3=Color3.fromRGB(255,255,255); VerifyBtn.Font=Enum.Font.GothamBold; VerifyBtn.TextSize=14
    Instance.new("UICorner", VerifyBtn).CornerRadius=UDim.new(0,8)

    local GetKeyBtn = Instance.new("TextButton", MF)
    GetKeyBtn.Text="Get Key"; GetKeyBtn.Size=UDim2.new(1,0,0,20); GetKeyBtn.Position=UDim2.new(0,0,1,-25); GetKeyBtn.BackgroundTransparency=1
    GetKeyBtn.TextColor3=Color3.fromRGB(100,100,100); GetKeyBtn.Font=Enum.Font.Gotham; GetKeyBtn.TextSize=12
    GetKeyBtn.MouseButton1Click:Connect(function()
        pcall(function() setclipboard(SECRETS.Discord) end)
        if GetKeyBtn and GetKeyBtn.Parent then
            GetKeyBtn.Text = "Copied!"; task.wait(1.5); if GetKeyBtn and GetKeyBtn.Parent then GetKeyBtn.Text = "Get Key" end
        end
    end)

    local function ShakeMF()
        local orig = MF.Position
        for _ = 1,4 do MF.Position = orig + UDim2.new(0,4,0,0); task.wait(0.05); MF.Position = orig - UDim2.new(0,4,0,0); task.wait(0.05) end
        MF.Position = orig
    end

    VerifyBtn.MouseButton1Click:Connect(function()
        local input = string.upper(InputBox.Text)
        if input == "" then return end
        VerifyBtn.Text = "Checking..."; VerifyBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)

        local checking = true
        task.spawn(function()
            local t = 0
            while checking do
                t = t + 0.05
                local alpha = (math.sin(t * 4) + 1) / 2
                local r = math.floor(230 + alpha * 15); local g = math.floor(8 + alpha * 20); local b2 = math.floor(82 + alpha * 20)
                pcall(function() VerifyBtn.BackgroundColor3 = Color3.fromRGB(r,g,b2) end)
                task.wait(0.05)
            end
        end)
        local isValid, isExpired, _, expTime, isGlobal, tier = VerifyKeyWithServer(input)
        checking = false 
        if isValid and not isExpired then
            if not isGlobal then SaveKey(input, expTime) end
            BottleLib.KeyStatus = { Valid=true, ExpiresAt=tonumber(expTime), IsGlobal=isGlobal, Tier=tier or "Basic" }
            VerifyBtn.Text = "Success!"; VerifyBtn.BackgroundColor3 = Color3.fromRGB(46,204,113)
