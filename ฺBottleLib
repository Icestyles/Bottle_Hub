    local function ToggleMinimize(hide) MainFrame.Visible  = not hide; MiniButton.Visible = hide end
    MiniButton.MouseButton1Click:Connect(function() ToggleMinimize(false) end)

    local ctrlConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if input.KeyCode == Enum.KeyCode.LeftControl and not gameProcessed then
            if MainFrame and MainFrame.Parent then ToggleMinimize(MainFrame.Visible) end
