        function APIObj:CreateFolder(folderName, isPremiumFolder)
            local folderFrame = Instance.new("Frame", targetContainer)
            folderFrame.Size = UDim2.new(1,0,0,34)
            folderFrame.AutomaticSize = Enum.AutomaticSize.Y
            folderFrame.BackgroundColor3 = Color3.fromRGB(15,15,15)
            Instance.new("UICorner", folderFrame).CornerRadius = UDim.new(0,4)
            local fStroke = Instance.new("UIStroke", folderFrame)
            fStroke.Color = Color3.fromRGB(35,35,35)

            local fLayout = Instance.new("UIListLayout", folderFrame)
            fLayout.SortOrder = Enum.SortOrder.LayoutOrder
            
            local headerBtn = Instance.new("TextButton", folderFrame)
            headerBtn.Size = UDim2.new(1,0,0,34)
            headerBtn.BackgroundTransparency = 1
            
            local hexAccent = string.format("#%02X%02X%02X", math.floor(T.Accent.R*255), math.floor(T.Accent.G*255), math.floor(T.Accent.B*255))
            local pTag = isPremiumFolder and " <font color='"..hexAccent.."'>[VIP]</font>" or ""
            headerBtn.Text = "  ▼  " .. folderName .. pTag
            headerBtn.RichText = true
            headerBtn.TextColor3 = T.Text
            headerBtn.Font = Enum.Font.GothamBold
            headerBtn.TextSize = 12
            headerBtn.TextXAlignment = Enum.TextXAlignment.Left

            local innerContainer = Instance.new("Frame", folderFrame)
            innerContainer.Size = UDim2.new(1,0,0,0)
            innerContainer.AutomaticSize = Enum.AutomaticSize.Y
            innerContainer.BackgroundTransparency = 1
            innerContainer.ClipsDescendants = true
            
            local innerLayout = Instance.new("UIListLayout", innerContainer)
            innerLayout.SortOrder = Enum.SortOrder.LayoutOrder
            innerLayout.Padding = UDim.new(0,6)
            local innerPad = Instance.new("UIPadding", innerContainer)
            innerPad.PaddingTop = UDim.new(0,0)
            innerPad.PaddingBottom = UDim.new(0,8)
            innerPad.PaddingLeft = UDim.new(0,10)
            innerPad.PaddingRight = UDim.new(0,10)

            local isOpen = true
            headerBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                innerContainer.Visible = isOpen
                headerBtn.Text = (isOpen and "  ▼  " or "  ▶  ") .. folderName .. pTag
            end)

            local FolderObj = {}
            -- ผูก API เข้ากับโฟลเดอร์ โดยถ้า isPremiumFolder เป็น true ทุกฟังก์ชันข้างในจะติด Guard ป้องกันทันที
            BindUIElements(FolderObj, innerContainer, isPremiumFolder)
            return FolderObj
        end
    end

    -- ──────────────────────────────────────────────────────────
    -- 📁 TAB CREATION
    -- ──────────────────────────────────────────────────────────
    local tabList = {}; local currentTab = nil
    
    local ContentMainFrame = Instance.new("Frame", ContentContainer)
    ContentMainFrame.Size = UDim2.new(1,0,1,0)
    ContentMainFrame.BackgroundTransparency = 1

    function WindowObj:CreateTab(TabName)
        local tabBtn = Instance.new("TextButton", TabScrollContainer)
        tabBtn.Size = UDim2.new(0.87,0,0,33); tabBtn.BackgroundColor3 = T.Sidebar; tabBtn.Text = TabName; tabBtn.TextColor3 = T.SubText; tabBtn.Font = Enum.Font.GothamBold; tabBtn.TextSize = 12; tabBtn.AutoButtonColor = false; tabBtn.ZIndex = 4
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0,4)

        tabBtn.MouseEnter:Connect(function() if currentTab and currentTab.Btn ~= tabBtn then TweenService:Create(tabBtn, TweenInfo.new(0.2), {BackgroundColor3=Color3.fromRGB(20,20,20)}):Play() end end)
        tabBtn.MouseLeave:Connect(function() if currentTab and currentTab.Btn ~= tabBtn then TweenService:Create(tabBtn, TweenInfo.new(0.2), {BackgroundColor3=T.Sidebar}):Play() end end)

        local line = Instance.new("Frame", tabBtn)
        line.Size = UDim2.new(0,3,0.6,0); line.Position = UDim2.new(0,0,0.2,0); line.BackgroundColor3 = Color3.fromRGB(255, 255, 255); line.BackgroundTransparency = 1
        Instance.new("UICorner", line).CornerRadius = UDim.new(1,0)

        local scroll = Instance.new("ScrollingFrame", ContentMainFrame)
        scroll.Size = UDim2.new(1,0,1,0); scroll.Position = UDim2.new(0,0,0,0); scroll.BackgroundTransparency = 1; scroll.ScrollBarThickness = 2; scroll.ScrollBarImageColor3 = T.Accent; scroll.BorderSizePixel = 0; scroll.Visible = false
        
        local layout = Instance.new("UIListLayout", scroll)
        layout.SortOrder = Enum.SortOrder.LayoutOrder; layout.Padding = UDim.new(0,8)
        local contentPad = Instance.new("UIPadding", scroll)
        contentPad.PaddingTop = UDim.new(0,10); contentPad.PaddingBottom = UDim.new(0,10); contentPad.PaddingLeft = UDim.new(0,15); contentPad.PaddingRight = UDim.new(0,15)
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() scroll.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y + 20) end)

        tabBtn.MouseButton1Click:Connect(function()
            if currentTab then
                TweenService:Create(currentTab.Btn, TweenInfo.new(0.18), {BackgroundColor3=T.Sidebar, TextColor3=T.SubText}):Play()
                TweenService:Create(currentTab.Line, TweenInfo.new(0.18), {BackgroundTransparency=1}):Play()
                currentTab.Frame.Visible = false
            end
            currentTab = {Btn=tabBtn, Frame=scroll, Line=line}
            TweenService:Create(tabBtn, TweenInfo.new(0.18), {BackgroundColor3=T.Accent, TextColor3=Color3.fromRGB(255,255,255)}):Play()
            TweenService:Create(line,   TweenInfo.new(0.18), {BackgroundTransparency=0}):Play()
            scroll.Visible = true
            if WindowObj.ActiveDropdown then WindowObj.ActiveDropdown.Visible = false; WindowObj.ActiveDropdown = nil; GlobalOverlayClose.Visible = false end
        end)

        table.insert(tabList, {Btn=tabBtn, Frame=scroll, Line=line})
        if #tabList == 1 then
            tabBtn.BackgroundColor3 = T.Accent; tabBtn.TextColor3 = Color3.fromRGB(255,255,255)
            line.BackgroundTransparency = 0; scroll.Visible = true; currentTab = {Btn=tabBtn, Frame=scroll, Line=line}
        end

        local TabObj = {}
        BindUIElements(TabObj, scroll, false) -- Base tab is not premium by default
        return TabObj
    end

    if WindowConfig.AutoMinimize then ToggleMinimize(true) end
    return WindowObj
