            end

            local DropObj = {}; function DropObj:Refresh(newList) optionsList = newList; RefreshList(Input.Text) end
            Input.Focused:Connect(function()
                if not checkPerm() then Input:ReleaseFocus(); return end
                if WindowObj.ActiveDropdown and WindowObj.ActiveDropdown ~= DropOverlay then WindowObj.ActiveDropdown.Visible = false end
                WindowObj.ActiveDropdown = DropOverlay
                local pos = frame.AbsolutePosition; local sz = frame.AbsoluteSize; local yPos = pos.Y + sz.Y + 4
                if yPos + 160 > ScreenGui.AbsoluteSize.Y then yPos = pos.Y - 164 end
                DropOverlay.Position = UDim2.new(0, pos.X, 0, yPos); DropOverlay.Size = UDim2.new(0, math.max(sz.X, 220), 0, 160)
                RefreshList(Input.Text); DropOverlay.Visible = true; GlobalOverlayClose.Visible = true
            end)
            Input:GetPropertyChangedSignal("Text"):Connect(function() if DropOverlay.Visible and not selectedFromList then RefreshList(Input.Text) end end)
            Input.FocusLost:Connect(function() if selectedFromList then selectedFromList = false; return end; if Input.Text ~= "" then callback(Input.Text) end end)
            return DropObj
        end

        function APIObj:CreateDualKeyRow(l1, l2, callback1, callback2, default1, default2)
