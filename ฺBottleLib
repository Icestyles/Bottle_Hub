        VerifyBtn.Text = "Checking..."; VerifyBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)
        local checking = true
        task.spawn(function()
            local t = 0
            while checking do
                t = t + 0.05; local alpha = (math.sin(t * 4) + 1) / 2; local r = math.floor(230 + alpha * 15); local g = math.floor(8 + alpha * 20); local b2 = math.floor(82 + alpha * 20)
                pcall(function() VerifyBtn.BackgroundColor3 = Color3.fromRGB(r,g,b2) end); task.wait(0.05)
            end
        end)
        local isValid, isExpired, _, expTime, isGlobal, tier = VerifyKeyWithServer(input)
        checking = false 
        if isValid and not isExpired then
            if not isGlobal then SaveKey(input, expTime) end
            BottleLib.KeyStatus = { Valid=true, ExpiresAt=tonumber(expTime), IsGlobal=isGlobal, Tier=tier or "Basic", KeyName=input, HWID=self:GetHWID() }
            VerifyBtn.Text = "Success!"; VerifyBtn.BackgroundColor3 = Color3.fromRGB(46,204,113)
            task.wait(0.5); KeyScreen:Destroy(); VerifyEvent:Fire()
