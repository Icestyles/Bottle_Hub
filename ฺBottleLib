    local arc = Instance.new("Frame", ring)
    arc.Size = UDim2.new(1,0,1,0); arc.Position = UDim2.new(0,0,0,0)
    arc.BackgroundTransparency = 1; arc.ZIndex = 92; Instance.new("UICorner", arc).CornerRadius = UDim.new(1,0)

    local arcStroke = Instance.new("UIStroke", arc)
    arcStroke.Color = Color3.fromRGB(255,255,255); arcStroke.Thickness = 3
    local gradient = Instance.new("UIGradient", arcStroke)
    gradient.Color = ColorSequence.new(Color3.fromHex("#e60852")) 
    gradient.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(0.7, 1), NumberSequenceKeypoint.new(1, 1)     
    })
    gradient.Rotation = 180

    local angle = 0
    _loaderSpinConn = RunService.Heartbeat:Connect(function(dt)
        if not ring or not ring.Parent then return end
        angle = (angle + dt * 320) % 360; ring.Rotation = angle
    end)

    local msgLbl = Instance.new("TextLabel", card)
    msgLbl.Size = UDim2.new(1,-20,0,20); msgLbl.Position = UDim2.new(0,10,0,72)
    msgLbl.BackgroundTransparency = 1; msgLbl.Text = message; msgLbl.TextColor3 = Color3.fromRGB(200,200,200)
    msgLbl.Font = Enum.Font.GothamMedium; msgLbl.TextSize = 12; msgLbl.ZIndex = 92

    local dotTimer = 0; local dotCount = 0
    _loaderDotsConn = RunService.Heartbeat:Connect(function(dt)
        if not msgLbl or not msgLbl.Parent then return end
        dotTimer = dotTimer + dt
        if dotTimer >= 0.4 then 
            dotTimer = 0; dotCount = (dotCount + 1) % 4
            msgLbl.Text = message .. string.rep(".", dotCount)
        end
    end)

    task.spawn(function()
        local pulseDir = 1; local alpha = 0
        while card and card.Parent do
            alpha = alpha + 0.02 * pulseDir
            if alpha >= 1 then alpha = 1; pulseDir = -1 elseif alpha <= 0 then alpha = 0; pulseDir = 1 end
            pcall(function() stroke.Transparency = 0.3 + alpha * 0.5 end)
            task.wait(0.03)
        end
    end)

    card.Size = UDim2.new(0,180,0,80); card.Position = UDim2.new(0.5,-90,0.5,-40)
    TweenService:Create(card, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Size = UDim2.new(0,220,0,110), Position = UDim2.new(0.5,-110,0.5,-55) }):Play()
end

function BottleLib:HideLoader()
    if _loaderSpinConn then _loaderSpinConn:Disconnect(); _loaderSpinConn = nil end
    if _loaderDotsConn then _loaderDotsConn:Disconnect(); _loaderDotsConn = nil end
    if _loaderGui and _loaderGui.Parent then
        local overlay = _loaderGui:FindFirstChildWhichIsA("Frame")
        if overlay then TweenService:Create(overlay, TweenInfo.new(0.25), { BackgroundTransparency = 1 }):Play() end
        task.delay(0.25, function() if _loaderGui and _loaderGui.Parent then _loaderGui:Destroy() end; _loaderGui = nil end)
    end
end

