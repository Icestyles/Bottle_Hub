    knob.Size = UDim2.new(0, 20, 0, 20)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.Position = default and UDim2.new(0, 18, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = switchBg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local isOn = default
    switchBg.MouseButton1Click:Connect(function()
        isOn = not isOn
        local targetPos = isOn and UDim2.new(0, 18, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
        local targetColor = isOn and Theme.Accent or Color3.fromRGB(60, 60, 60)
