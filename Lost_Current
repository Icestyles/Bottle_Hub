local function ToggleESP(n, t, c, s)
    Toggles[n]=s
    local f = Workspace:FindFirstChild("Materials") and Workspace.Materials:FindFirstChild(n == "Barrel" and "Barrels" or n == "Gold" and "Gold" or "Scrap")
    if n == "Barrel" then f = Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("Barrels") end
    if s and f then
        for _,v in pairs(f:GetChildren()) do if v.Name:lower():find(t:lower()) then CreateESP(v,t,c) end end
        table.insert(Connections, f.ChildAdded:Connect(function(v) if Toggles[n] and v.Name:lower():find(t:lower()) then task.wait(0.1) CreateESP(v,t,c) end end))
    end
end
-- ESP Helper
function CreateESP(p,t,c)
    if not p or not p:IsA("BasePart") or ActiveESP[p] then return end
    local h=Instance.new("Highlight",p); h.FillColor=c; h.OutlineTransparency=1
    local b=Instance.new("BillboardGui",p); b.Size=UDim2.new(0,100,0,30); b.AlwaysOnTop=true
    local l=Instance.new("TextLabel",b); l.Size=UDim2.new(1,0,1,0); l.Text=t; l.TextColor3=c; l.BackgroundTransparency=1; l.Font=Enum.Font.GothamBold; l.TextStrokeTransparency=0.5
    ActiveESP[p]={Highlight=h,Billboard=b,Label=l,Type=t}
end
-- Update Loop
table.insert(Connections, RunService.Heartbeat:Connect(function()
    if tick()-(_G.LUE or 0)<0.2 then return end; _G.LUE=tick()
    local c=LocalPlayer.Character; local r=c and c:FindFirstChild("HumanoidRootPart")
    for p,e in pairs(ActiveESP) do
        if p.Parent and Toggles[e.Type] and r then
            local d=(r.Position-p.Position).Magnitude
            if d<=Config.MaxDistance then e.Highlight.Enabled=true; e.Billboard.Enabled=true; e.Label.Text=string.format("[%d] %s",d,e.Type)
            else e.Highlight.Enabled=false; e.Billboard.Enabled=false end
        else if not p.Parent then e.Highlight:Destroy(); e.Billboard:Destroy(); ActiveESP[p]=nil else e.Highlight.Enabled=false; e.Billboard.Enabled=false end end
    end
end))

