local function CreateESP(part, typeName, color)
    if not part or not part:IsA("BasePart") or ActiveESP[part] then return end
    local hl = Instance.new("Highlight"); hl.FillColor = color; hl.OutlineTransparency=1; hl.Parent = part
    local bb = Instance.new("BillboardGui"); bb.Size=UDim2.new(0,100,0,30); bb.AlwaysOnTop=true; bb.Parent=part
    local tx = Instance.new("TextLabel"); tx.Size=UDim2.new(1,0,1,0); tx.Text=typeName; tx.TextColor3=color; tx.BackgroundTransparency=1; tx.TextStrokeTransparency=0.5; tx.Font=Enum.Font.GothamBold; tx.Parent=bb
    ActiveESP[part] = {Highlight=hl, Billboard=bb, Label=tx, Type=typeName}
end

local function ToggleESP(name, typeName, color, state)
    Toggles[name] = state
    local folderMap = {
        Gold = {Workspace:FindFirstChild("Materials"), "Gold"},
        Scrap = {Workspace:FindFirstChild("Materials"), "Scrap"}
    }
    local fData = folderMap[name]
    if not fData[1] then return end
    local folder = fData[1]:FindFirstChild(fData[2])
    if state then
        if folder then
            for _, c in pairs(folder:GetChildren()) do
                if c.Name:lower():find(typeName:lower()) then CreateESP(c, typeName, color) end
            end
            local conn = folder.ChildAdded:Connect(function(c)
                if Toggles[name] and c.Name:lower():find(typeName:lower()) then task.wait(0.1); CreateESP(c, typeName, color) end
            end)
            table.insert(Connections, conn)
        end
    end
end

