local function UpdateSafeZone()
    local boat = Workspace:FindFirstChild("Boat")
    if not boat then 
        if SafePlatformPart then SafePlatformPart.CFrame = CFrame.new(0, -9000, 0) end
        return nil
    end
    if not SafePlatformPart or not SafePlatformPart.Parent then
        SafePlatformPart = Instance.new("Part")
        SafePlatformPart.Name = "AutoFarm_SafeZone"
        SafePlatformPart.Size = Vector3.new(20, 1, 20)
        SafePlatformPart.Anchored = true; SafePlatformPart.CanCollide = true
        SafePlatformPart.Material = Enum.Material.ForceField
        SafePlatformPart.Color = Color3.fromRGB(0, 255, 255); SafePlatformPart.Transparency = 0.8
        SafePlatformPart.Parent = Workspace
    end
    SafePlatformPart.CFrame = boat:GetPivot() + Config.SafeZoneOffset
    return SafePlatformPart
end

local function SetupHealthMonitor()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if not hum then return end
    CurrentHealth = hum.Health
    local conn = hum.HealthChanged:Connect(function(newHealth)
        if Toggles.FarmGold and newHealth < CurrentHealth then
            -- Smart Safety Logic Integrated here
            warn("⚠️ Safety Triggered: Damage Taken")
            -- Simple logic: Refresh safe zone or blacklist area if needed
        end
        CurrentHealth = newHealth
    end)
    table.insert(Connections, conn)
end
table.insert(Connections, LocalPlayer.CharacterAdded:Connect(function() task.wait(1) SetupHealthMonitor() end))

local function StartAutoSystem()
    task.spawn(function()
        SetupHealthMonitor()
        while Toggles.FarmGold do
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then task.wait(1); continue end
            
            local safeZone = UpdateSafeZone()
            
            -- [INTEGRATED] Auto Bucket Logic
            local waterLevel = 0
            local levelObj = Workspace:FindFirstChild("Boat") and Workspace.Boat:FindFirstChild("WaterFlood") and Workspace.Boat.WaterFlood:FindFirstChild("Level")
            if levelObj then waterLevel = levelObj.Value end

            if waterLevel >= Config.WaterTriggerLevel then
                StopDriving()
                local union = Workspace:FindFirstChild("Boat") and Workspace.Boat:FindFirstChild("Body") and Workspace.Boat.Body:FindFirstChild("Union")
                if union then
                    local targetCF = union.CFrame + Vector3.new(0, 3, 0)
                    GetFarmPlatforms(targetCF)
                    TeleportTo(targetCF)
                    task.wait(0.3)
                    SendKey(Enum.KeyCode.E, Config.BucketHoldTime)
                    HideFarmPlatforms()
                end
                if safeZone then TeleportTo(safeZone.CFrame + Vector3.new(0, 3, 0)) end
                task.wait(1)
                continue
            end

            -- [CORE] Find Gold
            local goldFolder = Workspace:FindFirstChild("Materials") and Workspace.Materials:FindFirstChild("Gold")
            local targetGold, minDist = nil, math.huge
            local rootPos = char.HumanoidRootPart.Position

            if goldFolder then
                for _, child in pairs(goldFolder:GetChildren()) do
                    if child:IsA("BasePart") and child.Transparency < 1 and not GoldBlacklist[child] then
                        local dist = (child.Position - rootPos).Magnitude
                        if dist < minDist then minDist = dist; targetGold = child end
                    end
                end
            end

            if targetGold then
                if IsDriving then StopDriving() end
                local attempts = GoldAttemptHistory[targetGold] or 0
                if attempts >= Config.MaxBugAttempts then GoldBlacklist[targetGold] = true; continue end
                GoldAttemptHistory[targetGold] = attempts + 1

                GetFarmPlatforms(targetGold.CFrame)
                TeleportTo(targetGold.CFrame)
                task.wait(0.2)
                if Toggles.FarmGold then SendKey(Enum.KeyCode.E, Config.GoldHoldTime) end
                HideFarmPlatforms()
                if safeZone then TeleportTo(safeZone.CFrame + Vector3.new(0, 3, 0)) end
                task.wait(Config.FarmWaitTime)
            else
                if SafePlatformPart then SafePlatformPart.CFrame = CFrame.new(0, -9000, 0) end
                -- Simple Driving Logic
                if not IsDriving then 
                    local seat = Workspace:FindFirstChild("Boat") and Workspace.Boat:FindFirstChild("DrivingSeat") and Workspace.Boat.DrivingSeat:FindFirstChild("Seat")
                    if seat then 
                        IsDriving = true; seat:Sit(char.Humanoid); task.wait(0.5); VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, game)
                    end
                end
                task.wait(0.1)
            end
            task.wait(0.1)
        end
        StopDriving()
    end)
end

