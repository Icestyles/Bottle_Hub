local function HasQuest(questID)
    local quests = LocalPlayer:FindFirstChild("Quests")
    if quests then
        if quests:FindFirstChild(questID) then
            return true
        end
    end
    return false
end

-- ==========================================
-- REMOTE HELPER
-- ==========================================
local function FireRemote(type, name, ...)
    local args = {...}
    task.spawn(function()
        local remoteFolder = workspace:WaitForChild("Remote", 5)
        if not remoteFolder then return end
        
        if type == "Fire" then
            local remote = remoteFolder:WaitForChild(name, 5)
            if remote then 
                remote:FireServer(unpack(args)) 
            end
        elseif type == "Invoke" then
            local remote = remoteFolder:WaitForChild(name, 5)
            if remote then 
                remote:InvokeServer(unpack(args)) 
            end
        end
    end)
end

