local function GetHumanoid(model)
    if not model then return nil end
    return model:FindFirstChild("Humanoid") or model:FindFirstChild("Enemy")
end

-- ==========================================
-- MOVEMENT LOGIC (PLATFORM STAND)
-- ==========================================
local function TweenToTarget(targetPart)
    if not targetPart or not LocalPlayer.Character then return end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local char = LocalPlayer.Character
    local humanoid = char:FindFirstChild("Humanoid")

    if TweenConnection then TweenConnection:Disconnect() TweenConnection = nil end
    
    if humanoid then 
        humanoid.PlatformStand = true 
        humanoid.AutoRotate = false
    end
    
    local tweenInfo = TweenInfo.new(Config.TweenSpeed, Enum.EasingStyle.Linear)
    
    TweenConnection = RunService.Heartbeat:Connect(function()
        local parent = targetPart and targetPart.Parent
        local targetHumanoid = GetHumanoid(parent)
        
        if not Config.AutoQuestEnabled or not parent or not targetHumanoid or targetHumanoid.Health <= 0 then
            if TweenConnection then TweenConnection:Disconnect() TweenConnection = nil end
            if humanoid then 
                humanoid.PlatformStand = false
                humanoid.AutoRotate = true
            end
            return
        end
        
        if hrp then
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.RotVelocity = Vector3.new(0, 0, 0)
            
            local targetPos = targetPart.Position + Vector3.new(0, Config.AttackDistance, 0)
            local goalCFrame = CFrame.new(targetPos) * CFrame.Angles(math.rad(-90), 0, 0)
            
            local tween = TweenService:Create(hrp, tweenInfo, {CFrame = goalCFrame})
            tween:Play()
        end
    end)
end

-- ==========================================
-- COMBAT LOGIC
-- ==========================================
local function SkillRotation()
    while SkillCycleRunning and Config.AutoQuestEnabled do
        for i = 1, #SkillOrder do
            if not SkillCycleRunning or not Config.AutoQuestEnabled then break end
            PressKey(SkillOrder[i])
            task.wait(Config.SkillDelay)
        end
        task.wait(0.1)
    end
end

local function AutoAttack()
    while AttackLoopRunning and Config.AutoQuestEnabled do
        ClickMouse()
        task.wait(0.1)
    end
end

local function UpdateWeaponSlots()
    if not GUI then return end
    local WeaponFrame = GUI.MainFrame:FindFirstChild("WeaponFrame")
    if not WeaponFrame then return end
    for i = 1, 4 do
        local SlotInput = WeaponFrame:FindFirstChild("Slot"..i)
        if SlotInput then
            local txt = SlotInput.Text
            if NumberKeys[txt] then WeaponSlots[i] = NumberKeys[txt] else WeaponSlots[i] = nil end
        end
    end
end

local function WeaponRotationLoop()
    UpdateWeaponSlots()
    local mainKey = WeaponSlots[1]
    local char = LocalPlayer.Character
    local holdingTool = char and char:FindFirstChildOfClass("Tool")
    
    if mainKey then
        if holdingTool or CurrentEquippedKey == mainKey then
            CurrentEquippedKey = mainKey 
        else
            PressKey(mainKey)
            CurrentEquippedKey = mainKey
            task.wait(0.5)
        end
    end

    while WeaponRotationRunning and Config.AutoQuestEnabled do
        local activeWeaponsCount = 0
        for i = 1, 4 do if WeaponSlots[i] then activeWeaponsCount = activeWeaponsCount + 1 end end
        local baseCycleTime = 12 
        local timePerStage = 2
        local autoAttackDuration = baseCycleTime - (activeWeaponsCount * timePerStage)
        if autoAttackDuration < 1 then autoAttackDuration = 1 end

        for i = 1, 4 do
            local key = WeaponSlots[i]
            if key then
                if not WeaponRotationRunning or not Config.AutoQuestEnabled then return end
                
                if CurrentEquippedKey ~= key then
                    PressKey(key)
                    CurrentEquippedKey = key
                    task.wait(0.5) 
                end

                for _, skill in pairs(SkillOrder) do
                    PressKey(skill)
                    task.wait(0.1)
                end
                
                if i > 1 then HoldMouse(0.3) end
                task.wait(0.5)
            end
        end
        
        if WeaponSlots[1] then
            if CurrentEquippedKey ~= WeaponSlots[1] then
                PressKey(WeaponSlots[1])
                CurrentEquippedKey = WeaponSlots[1]
                task.wait(0.5)
            end
            local timer = 0
            while timer < autoAttackDuration and WeaponRotationRunning and Config.AutoQuestEnabled do
                ClickMouse()
                task.wait(0.1)
                timer = timer + 0.1
            end
        end
        task.wait(0.1)
    end
end

local function StopCombat()
    WeaponRotationRunning = false
    SkillCycleRunning = false
    AttackLoopRunning = false
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.PlatformStand = false
        LocalPlayer.Character.Humanoid.AutoRotate = true
    end
end

local function StartCombat()
    if not WeaponRotationRunning then 
        WeaponRotationRunning = true 
        task.spawn(WeaponRotationLoop) 
    end
    if not SkillCycleRunning then 
        SkillCycleRunning = true 
        task.spawn(SkillRotation) 
    end
    if not AttackLoopRunning then 
        AttackLoopRunning = true 
        task.spawn(AutoAttack) 
    end
end

-- ==========================================
-- MAIN AUTO QUEST LOOP (REFINED)
-- ==========================================
local function FindQuestTarget()
    local questInfo = QuestData[Config.SelectedQuest]
    if not questInfo then return nil end
    
    local folder = questInfo.TargetPath()
    if folder and folder:FindFirstChild(questInfo.TargetName) then
        local target = folder[questInfo.TargetName]
        local humanoid = GetHumanoid(target)
        
        if target:FindFirstChild("HumanoidRootPart") and humanoid and humanoid.Health > 0 then
            return target
        end
    end
    return nil
end

local function AutoQuestLoop()
    while Config.AutoQuestEnabled do
        local target = FindQuestTarget()
        local questInfo = QuestData[Config.SelectedQuest]
        
        if target then
            -- [CASE 1] เจอบอส
            if CurrentTarget ~= target then
                CurrentTarget = target
                print("AutoQuest: Target Found -> " .. target.Name)
                
                -- ถ้ายังไม่มีเควส ให้รับ (StartQuest)
                if questInfo and questInfo.QuestID and not HasQuest(questInfo.QuestID) then
                     print("Quest: StartQuest -> " .. questInfo.QuestID)
                     FireRemote("Invoke", "QuestFunction", "Check", questInfo.QuestID)
                     FireRemote("Fire", "QuestEvent", "StartQuest", questInfo.QuestID)
                end
                
                TweenToTarget(target.HumanoidRootPart)
                StartCombat()
            end
        else
            -- [CASE 2] ไม่เจอบอส (Turn In Logic)
            CurrentTarget = nil
            StopCombat() 
            if TweenConnection then TweenConnection:Disconnect() TweenConnection = nil end 
            
            if questInfo and questInfo.QuestID then
                if HasQuest(questInfo.QuestID) then
                    -- มีเควสค้างอยู่ = เควสเสร็จแล้วแต่บอสตาย ให้ส่งเควส (Repeat)
                    -- ยิงซ้ำๆ ทุก Loop จนกว่าเควสจะหายไป (Force Turn In)
                    print("Quest: Turning In (QuestRepeat)...")
                    FireRemote("Fire", "QuestRepeat", questInfo.QuestID)
                else
                    -- ไม่มีเควส = ส่งเสร็จแล้ว ให้รับใหม่ (Start)
                    print("Quest: Accepting New (StartQuest)...")
                    FireRemote("Invoke", "QuestFunction", "Check", questInfo.QuestID)
                    FireRemote("Fire", "QuestEvent", "StartQuest", questInfo.QuestID)
                end
            end
            
            -- ทำ PreLogic ถ้ายังไม่มีเควส หรือพึ่งรับเควสมา
            if questInfo and questInfo.HasPreLogic and not PreLogicRunning then
                -- ถ้าไม่มีเควส อย่าพึ่งวิ่งไป ให้รับเควสให้ได้ก่อน (Logic ด้านบนจะจัดการรับ)
                -- แต่อนุญาตให้วิ่งถ้ามีเควสแล้ว
                if questInfo.QuestID and HasQuest(questInfo.QuestID) then
                    PreLogicRunning = true
                    print("AutoQuest: Running Pre-Logic...")
                    questInfo.PreLogic()
                    PreLogicRunning = false
                end
            end
        end
        task.wait(0.5) -- Loop Tick
    end
    
    StopCombat()
    if TweenConnection then TweenConnection:Disconnect() TweenConnection = nil end
    CurrentTarget = nil
    PreLogicRunning = false
end

