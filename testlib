function BottleLib:GetBackendURL() return GetGasEndpoint() end

function BottleLib:GetHWID()
    if type(gethwid) == "function" then
        local ok, hwid = pcall(gethwid)
        if ok and hwid and hwid ~= "" then return hwid end
    end
    local ok, id = pcall(function() return RbxAnalyticsService:GetClientId() end)
    if ok and id and id ~= "" then return id end
    local HWID_FILE = "BottleHub_LocalHWID.txt"
    if isfile and isfile(HWID_FILE) and readfile then
        local rOk, saved = pcall(readfile, HWID_FILE)
        if rOk and type(saved) == "string" and saved ~= "" then return saved end
    end
    local newHwid = "FALLBACK-" .. HttpService:GenerateGUID(false)
    if writefile then pcall(writefile, HWID_FILE, newHwid) end
    return newHwid
end

function BottleLib:SendAnalytics(scriptName)
    task.spawn(function()
        local url = self:GetBackendURL()
        local ok, info = pcall(function() return MarketplaceService:GetProductInfo(game.PlaceId) end)
        local gameName = ok and info.Name or game.Name
        local payload = {
            action = "log_stats", hwid = self:GetHWID(),
            placeId = gameName .. " (" .. tostring(game.PlaceId) .. ")",
            script = scriptName or "Unknown",
            key = self.KeyStatus.KeyName or "Unknown",
            tier = self.KeyStatus.Tier or "Basic"
        }
        local req = (syn and syn.request) or (http and http.request) or http_request or request
        if req then
            pcall(function()
                req({ Url=url, Method="POST", Body=HttpService:JSONEncode(payload), Headers={["Content-Type"]="application/json"} })
            end)
        end
    end)
end

-- ============================================================================
-- ✅ Phase 2 — HUBLOADER
-- เรียก BottleLib:LoadGameScript() ใน Main Script หลัง CreateWindow
-- GAS จะ match GameId/PlaceId → ดึงจาก GitHub Private → loadstring
-- ============================================================================
function BottleLib:LoadGameScript(onSuccess, onFail)
    task.spawn(function()
        local req = (syn and syn.request) or (http and http.request) or http_request or request
        if not req then
            if onFail then pcall(onFail, "No HTTP function available") end
            return
        end

        local url = string.format(
            "%s?action=get_script&gameId=%s&placeId=%s&hwid=%s&key=%s",
            GetGasEndpoint(),
            tostring(game.GameId),
            tostring(game.PlaceId),
            self:GetHWID(),
            self.KeyStatus.KeyName or "Unknown"
        )

        local ok, res = pcall(function() return req({ Url=url, Method="GET" }) end)
        if not ok or not res or not res.Body then
            if onFail then pcall(onFail, "Request failed") end
            return
        end

        local ok2, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
        if not ok2 or type(data) ~= "table" then
            if onFail then pcall(onFail, "Invalid response") end
            return
        end

        if not data.success then
            if onFail then pcall(onFail, data.message or "Unknown error") end
            return
        end

        if not data.content or data.content == "" then
            if onFail then pcall(onFail, "Empty script content") end
            return
        end

        -- loadstring และรัน Main Script
        local fn, err = loadstring(data.content)
        if not fn then
            if onFail then pcall(onFail, "loadstring error: " .. tostring(err)) end
            return
        end

        local runOk, runErr = pcall(fn)
        if not runOk then
            if onFail then pcall(onFail, "Script runtime error: " .. tostring(runErr)) end
            return
        end

        if onSuccess then pcall(onSuccess) end
    end)
end

