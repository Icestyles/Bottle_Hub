        local selected, pillButtons = {}, {}
        local function getSelectedList() local list = {}; for _, opt in ipairs(options) do if selected[opt] then table.insert(list, opt) end end; return list end
        local function updatePillVisual(opt)
            local btn = pillButtons[opt]; if not btn then return end
            if selected[opt] then TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3=T.Accent, TextColor3=Color3.fromRGB(255,255,255)}):Play() else TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3=T.ElemDark, TextColor3=T.SubText}):Play() end
        end

        local function createPill(opt, order)
            local btn = Instance.new("TextButton", pillsFrame); btn.LayoutOrder = order; btn.Size = UDim2.new(0,0,0,28); btn.AutomaticSize = Enum.AutomaticSize.X; btn.BackgroundColor3 = T.ElemDark; btn.TextColor3 = T.SubText; btn.Font = Enum.Font.GothamBold; btn.TextSize = 12; btn.Text = "  " .. opt .. "  "; btn.AutoButtonColor = false; Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
            btn.MouseButton1Click:Connect(function() if checkPerm() then if multiSelect then selected[opt] = not selected[opt] else for k in pairs(selected) do selected[k] = false end; selected[opt] = true end; updatePillVisual(opt); if not multiSelect then for k in pairs(pillButtons) do updatePillVisual(k) end end; pcall(callback, getSelectedList(), opt) end end)
            pillButtons[opt] = btn; updatePillVisual(opt)
        end

        for i, opt in ipairs(options) do createPill(opt, i) end
        local SelectorObj = {}
        function SelectorObj:Refresh(newList) for _, btn in pairs(pillButtons) do btn:Destroy() end; table.clear(pillButtons); table.clear(selected); options = newList; for i, opt in ipairs(options) do createPill(opt, i) end end
        return SelectorObj
    end

