function BottleLib:InitVIPEvader()
    if self.KeyStatus.IsVIPUser then
        if self.EvaderDebug then self:Notify("VIP Evader: You are VIP — exempt.") end
        return
    end

    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if not req then
        if self.EvaderDebug then self:Notify("VIP Evader DEBUG: No HTTP function.") end
        return
    end

    -- ✅ v13.6.2: ใช้ check_vip per player โดยตรง (proven ทำงานได้)
    -- ไม่ใช้ get_vips cache อีกต่อไป
    local function isVip(userId)
        local url = string.format("%s?action=check_vip&userId=%s", GetGasEndpoint(), tostring(userId))
        local ok, res = pcall(function() return req({ Url=url, Method="GET" }) end)
        if not ok or not res or not res.Body then return false end
        local ok2, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
        return ok2 and type(data) == "table" and data.vip == true
    end

    local function doHop()
        task.spawn(function()
            local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
            local ok, res = pcall(function() return req({ Url=url, Method="GET" }) end)
            if ok and res and res.Body then
                local ok2, decoded = pcall(function() return HttpService:JSONDecode(res.Body) end)
                if ok2 and decoded and decoded.data then
                    for _, v in ipairs(decoded.data) do
                        if v.id ~= game.JobId and v.playing < v.maxPlayers then
                            pcall(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, v.id, player) end)
                            return
                        end
                    end
                end
            end
            pcall(function() TeleportService:Teleport(game.PlaceId, player) end)
        end)
    end

    task.spawn(function()
        -- ตรวจ players ที่อยู่ในเซิฟแล้วทันที
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player then
                if self.EvaderDebug then self:Notify("VIP Evader DEBUG: Checking " .. plr.Name .. " (" .. plr.UserId .. ")") end
                if isVip(plr.UserId) then
                    if self.EvaderDebug then self:Notify("VIP Evader DEBUG: MATCH " .. plr.Name .. " → Hopping!") end
                    doHop(); return
                end
            end
        end

        if self.EvaderDebug then self:Notify("VIP Evader DEBUG: No VIP in server. Watching...") end

        -- ฟัง VIP ที่เข้ามาใหม่ระหว่างเล่น
        table.insert(BottleLib.Connections, Players.PlayerAdded:Connect(function(plr)
            if self.EvaderDebug then self:Notify("VIP Evader DEBUG: " .. plr.Name .. " joined, checking...") end
            task.spawn(function()
                if isVip(plr.UserId) then
                    if self.EvaderDebug then self:Notify("VIP Evader DEBUG: MATCH " .. plr.Name .. " → Hopping!") end
                    doHop()
                end
            end)
        end))
    end)
end

