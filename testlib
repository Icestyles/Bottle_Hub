    local function VerifyKeyWithServer(key)
        local url = string.format("%s?action=verify_key&key=%s&hwid=%s&placeId=UNKNOWN", GetGasEndpoint(), key, self:GetHWID())
        local res = MakeRequest(url)
        if res and res.Body then local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end); if ok and type(data) == "table" then return data.valid == true, data.expired == true, data.expirationTime or nil, data.isGlobal == true, data.accessLevel or "Basic" end end
        return false, false, nil, false, "Basic"
    end
