    if _loaderGui and _loaderGui.Parent then
        local overlay=_loaderGui:FindFirstChildWhichIsA("Frame")
        if overlay then TweenService:Create(overlay,TweenInfo.new(0.25),{BackgroundTransparency=1}):Play() end
        task.delay(0.25,function() if _loaderGui and _loaderGui.Parent then _loaderGui:Destroy() end; _loaderGui=nil end)
    end
end

