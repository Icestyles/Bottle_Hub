function BottleLib:GetHWID()
    if type(gethwid) == "function" then local ok, hwid = pcall(gethwid); if ok and hwid and hwid ~= "" then return hwid end end
    local ok, id = pcall(function() return RbxAnalyticsService:GetClientId() end); if ok and id and id ~= "" then return id end
    local HWID_FILE = "BottleHub_LocalHWID.txt"
    if isfile and isfile(HWID_FILE) and readfile then local rOk, saved = pcall(readfile, HWID_FILE); if rOk and type(saved) == "string" and saved ~= "" then return saved end end
    local newHwid = "FALLBACK-" .. HttpService:GenerateGUID(false); if writefile then pcall(writefile, HWID_FILE, newHwid) end
    return newHwid
end

