    -- =========================================================================
    -- ✅ v13.6: FOLDER (depth-aware) + SUB-FOLDER SUPPORT
    -- depth 0 = normal/premium folder
    -- depth 1+ = sub-folder (darker bg, indent, smaller header, dashed stroke)
    -- Premium inheritance: sub-folder inside premium folder inherits lock
    -- =========================================================================
    function APIObj:CreateFolder(folderName, isPremiumFolder)
        local isSubFolder = (_depth >= 1)

        -- Visual style differs by depth
        local bgColor     = isSubFolder and Color3.fromRGB(10,10,10) or Color3.fromRGB(15,15,15)
        local strokeColor = isSubFolder and Color3.fromRGB(28,28,28) or Color3.fromRGB(35,35,35)
        local headerH     = isSubFolder and 28 or 34
        local headerFs    = isSubFolder and 11 or 12
        local indentL     = isSubFolder and 8 or 0
        local indentR     = isSubFolder and 4 or 0

        local folderFrame=Instance.new("Frame",targetContainer)
        folderFrame.Size=UDim2.new(1,0,0,headerH); folderFrame.AutomaticSize=Enum.AutomaticSize.Y
        folderFrame.BackgroundColor3=bgColor; folderFrame.BorderSizePixel=0
        Instance.new("UICorner",folderFrame).CornerRadius=UDim.new(0,4)
        local fStroke=Instance.new("UIStroke",folderFrame); fStroke.Color=strokeColor; fStroke.Thickness=1
        if isSubFolder then fStroke.LineJoinMode=Enum.LineJoinMode.Round end

        local fLayout=Instance.new("UIListLayout",folderFrame); fLayout.SortOrder=Enum.SortOrder.LayoutOrder; fLayout.Padding=UDim.new(0,0)

        local hexAccent=string.format("#%02X%02X%02X",math.floor(T.Accent.R*255),math.floor(T.Accent.G*255),math.floor(T.Accent.B*255))

        local headerBtn=Instance.new("TextButton",folderFrame)
        headerBtn.Size=UDim2.new(1,0,0,headerH); headerBtn.BackgroundTransparency=1

        -- ✅ v13.6.1 FIX: accentBar เป็น child ของ headerBtn (ไม่อยู่ใน UIListLayout)
        if not isSubFolder then
            local accentBar=Instance.new("Frame",headerBtn)
            accentBar.Size=UDim2.new(0,3,1,0); accentBar.Position=UDim2.new(0,0,0,0)
            accentBar.BackgroundColor3=T.Accent; accentBar.BackgroundTransparency=0.4
            accentBar.BorderSizePixel=0; accentBar.ZIndex=2
            Instance.new("UICorner",accentBar).CornerRadius=UDim.new(0,4)
        end

        local arrowOpen  = "  ▼  "
        local arrowClose = "  ▶  "

        if isPremiumFolder then
            headerBtn.Text=arrowOpen.."<font color='"..hexAccent.."'>⭐ Premium Access</font>"
        elseif isSubFolder then
            headerBtn.Text=arrowOpen.."<font color='#888888'>"..folderName.."</font>"
        else
            headerBtn.Text=arrowOpen..folderName
        end
        headerBtn.RichText=true; headerBtn.TextColor3=T.Text; headerBtn.Font=Enum.Font.GothamBold
        headerBtn.TextSize=headerFs; headerBtn.TextXAlignment=Enum.TextXAlignment.Left

        local headerSep=Instance.new("Frame",folderFrame); headerSep.Size=UDim2.new(1,0,0,1); headerSep.BackgroundColor3=strokeColor; headerSep.BorderSizePixel=0; headerSep.Visible=true

        local innerContainer=Instance.new("Frame",folderFrame)
        innerContainer.Size=UDim2.new(1,0,0,0); innerContainer.AutomaticSize=Enum.AutomaticSize.Y
        innerContainer.BackgroundTransparency=1; innerContainer.ClipsDescendants=true

        local innerLayout=Instance.new("UIListLayout",innerContainer); innerLayout.SortOrder=Enum.SortOrder.LayoutOrder; innerLayout.Padding=UDim.new(0,isSubFolder and 4 or 6)
        local innerPad=Instance.new("UIPadding",innerContainer)
        innerPad.PaddingTop=UDim.new(0,isSubFolder and 4 or 6)
        innerPad.PaddingBottom=UDim.new(0,isSubFolder and 5 or 8)
        innerPad.PaddingLeft=UDim.new(0,(isSubFolder and 6 or 10)+indentL)
        innerPad.PaddingRight=UDim.new(0,(isSubFolder and 4 or 10)+indentR)

        local isOpen=true
        headerBtn.MouseButton1Click:Connect(function()
            isOpen=not isOpen; innerContainer.Visible=isOpen; headerSep.Visible=isOpen
            local arrow=isOpen and arrowOpen or arrowClose
            if isPremiumFolder then headerBtn.Text=arrow.."<font color='"..hexAccent.."'>⭐ Premium Access</font>"
            elseif isSubFolder then headerBtn.Text=arrow.."<font color='#888888'>"..folderName.."</font>"
            else headerBtn.Text=arrow..folderName end
        end)

        -- Premium inheritance: sub-folder inside a premium block inherits the lock
        local childIsPremium = isPremiumFolder and not isSubFolder and isPremiumBlock == false
        -- If this folder itself is premium → children are locked
        -- If parent is already premium (isPremiumBlock=true) → children inherit
        local childPremiumBlock = isPremiumFolder or isPremiumBlock

        local FolderObj={}
        BindUIElements(FolderObj, innerContainer, childPremiumBlock, T, WindowObj, ScreenGui, GlobalOverlayClose, _depth+1)
        return FolderObj
    end
