    local d = LoadStoredKey()
    if d and d.hwid == self:GetHWID() then
        if d.expiresAt and type(d.expiresAt) == "number" and os.time() >= d.expiresAt then pcall(delfile, KEY_STORAGE_FILE); player:Kick("BottleHub: Key expired."); return false end
        local isValid, isExpired, expTime, isGlobal, tier = VerifyKeyWithServer(d.key)
